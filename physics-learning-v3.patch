+/**
+ * src/features/mechanics/circular/rotating-disk/components/RotatingDiskScene.tsx
+ * 圆盘与圆锥摆物理视界场景内容
+ *
+ * ════════════════════════════════════════════════════════════════════════════
+ * 设计坐标说明：
+ * • splitH 预设：350×650
+ * • 内容使用设计坐标（0..350 / 0..650），由父组件 vp.transform 缩放
+ * • 父组件（RotatingDiskPage）负责 AnimationSvgCanvas 容器
+ *
+ * 合规要点（铁律 1/5）：
+ * • 铁律 5：复用 VectorArrow 组件
+ * • 铁律 1-1：颜色引用 theme token（KINEMATICS_COLORS / DYNAMICS_COLORS / CANVAS_COLORS）
+ * • 铁律 1-6：字体缩放使用 canvasSize.font()
+ * • 铁律 1-4：矢量走 VectorArrow 组件
+ * • 铁律 1-7：无 viewBox，使用设计坐标
+ * ════════════════════════════════════════════════════════════════════════════
+ */
+import React, { useCallback } from 'react'
+
+// ─── 可复用组件（铁律 5）─────────────────────────────────────────────
+import { VectorArrow } from '@/components/Physics'
+
+// ─── 类型与主题 ──────────────────────────────────────────────────────
+import type { RotatingDiskPhysicsResult } from '../hooks/useRotatingDiskPhysics'
+import type { CanvasSize } from '@/hooks'
+import {
+  KINEMATICS_COLORS,
+  DYNAMICS_COLORS,
+  SCENE_COLORS,
+  CANVAS_COLORS,
+} from '@/theme/physics'
+
+// ─── 场景专用材质色（inline — 无对应 theme token）────────────────────
+// 这些是纯粹的视觉外观色，不需要语义映射
+const _MATERIAL_STEEL = '#6B7280'   // 钢球主体
+const _MATERIAL_WOOD  = '#92400E'   // 木块主体
+const _MATERIAL_SHADOW = '#1F2937'  // 球体阴影
+const _MATERIAL_HIGHLIGHT = '#F9FAFB' // 高光
+
+interface RotatingDiskSceneProps {
+  physics: RotatingDiskPhysicsResult
+  model: 'cone-pendulum' | 'rotating-disk'
+  canvasSize: CanvasSize
+}
+
+/**
+ * 圆盘与圆锥摆场景内容（设计坐标）
+ *
+ * 渲染内容：
+ * 1. 中心轴线（rail.shadow）
+ * 2. 旋转轨迹（虚线圆 reference/trackHistory）
+ * 3. 悬绳/圆盘表面（circuit.wire/trackHistory）
+ * 4. 质点（steel/wood/material inline）
+ * 5. 矢量箭头（重力/拉力/向心力/速度）
+ * 6. SVG text 标注（θ/ω/向心力）
+ */
+export function RotatingDiskScene({ physics, model, canvasSize }: RotatingDiskSceneProps) {
+  const font = useCallback(
+    (size: number) => canvasSize.font(size),
+    [canvasSize]
+  )
+
+  const {
+    currentOmega,
+    thetaDeg,
+    centripetalForce,
+    isCritical,
+    isFlyOff,
+    safetyFactor,
+    centerX,
+    centerY,
+    topY,
+    particleX,
+    particleY,
+    gravityVector,
+    tensionVector,
+    centripetalVector,
+    frictionVector,
+    velocityVector,
+  } = physics
+
+  // 轨迹圆半径（设计像素）
+  const trackRadius = Math.abs(particleX - centerX) || 80
+
+  return (
+    <g>
+      {/* ─── 中心轴线（rail.shadow — 轴线深灰）────────────────── */}
+      <line
+        x1={centerX}
+        y1={topY - 20}
+        x2={centerX}
+        y2={centerY + 40}
+        stroke={SCENE_COLORS.rail.shadow}
+        strokeWidth={3}
+      />
+      {/* 轴顶端标记 */}
+      <circle cx={centerX} cy={topY - 20} r={6} fill={SCENE_COLORS.rail.shadow} />
+
+      {/* ─── 旋转轨迹（虚线圆）────────────────────────────── */}
+      {model === 'cone-pendulum' ? (
+        // 圆锥摆：水平旋转圆轨迹（虚线）→ reference 灰
+        <ellipse
+          cx={centerX}
+          cy={particleY}
+          rx={trackRadius}
+          ry={trackRadius * 0.15}
+          fill="none"
+          stroke={CANVAS_COLORS.reference}
+          strokeWidth={1}
+          strokeDasharray="4,4"
+          opacity={0.5}
+        />
+      ) : (
+        // 圆盘：圆盘表面（实线圆）→ trackHistory 填充 + rail.shadow 边缘
+        <circle
+          cx={centerX}
+          cy={centerY}
+          r={trackRadius}
+          fill={CANVAS_COLORS.trackHistory}
+          fillOpacity={0.15}
+          stroke={SCENE_COLORS.rail.shadow}
+          strokeWidth={1.5}
+        />
+      )}
+
+      {/* ─── 悬绳（圆锥摆模式）────────────────────────────── */}
+      {/* circuit.wire — 导绳色（#6B7280） */}
+      {model === 'cone-pendulum' && (
+        <line
+          x1={centerX}
+          y1={topY}
+          x2={particleX}
+          y2={particleY}
+          stroke={SCENE_COLORS.circuit.wire}
+          strokeWidth={2}
+        />
+      )}
+
+      {/* ─── 质点（球体）────────────────────────────── */}
+      {model === 'cone-pendulum' ? (
+        <g>
+          {/* 球体阴影 — inline #1F2937 */}
+          <circle
+            cx={particleX + 2}
+            cy={particleY + 3}
+            r={14}
+            fill={_MATERIAL_SHADOW}
+            opacity={0.3}
+          />
+          {/* 球体主体 — rail.body（#6B7280） */}
+          <circle
+            cx={particleX}
+            cy={particleY}
+            r={14}
+            fill={SCENE_COLORS.rail.body}
+          />
+          {/* 高光 — inline #F9FAFB */}
+          <circle
+            cx={particleX - 4}
+            cy={particleY - 4}
+            r={5}
+            fill={_MATERIAL_HIGHLIGHT}
+            opacity={0.6}
+          />
+        </g>
+      ) : (
+        <g>
+          {/* 圆盘上的物体（木块）— circuit.resistor（#92400E） */}
+          <rect
+            x={particleX - 10}
+            y={particleY - 10}
+            width={20}
+            height={20}
+            fill={SCENE_COLORS.circuit.resistor}
+            rx={2}
+          />
+          {/* 临界状态闪烁效果 — acceleration 红 */}
+          {isCritical && (
+            <rect
+              x={particleX - 12}
+              y={particleY - 12}
+              width={24}
+              height={24}
+              fill="none"
+              stroke={KINEMATICS_COLORS.acceleration}
+              strokeWidth={2}
+              opacity={0.6}
+            />
+          )}
+        </g>
+      )}
+
+      {/* ─── 矢量箭头层 ─────────────────────────────────── */}
+      <VectorsLayer
+        particleX={particleX}
+        particleY={particleY}
+        model={model}
+        gravity={gravityVector}
+        tension={tensionVector}
+        centripetal={centripetalVector}
+        friction={frictionVector}
+        velocity={velocityVector}
+        font={font}
+      />
+
+      {/* ─── 物理标注 ─────────────────────────────────── */}
+      <PhysicsAnnotations
+        physics={physics}
+        model={model}
+        centerX={centerX}
+        particleX={particleX}
+        particleY={particleY}
+        topY={topY}
+        font={font}
+        trackRadius={trackRadius}
+      />
+
+      {/* ─── 临界警告提示 ──────────────────────────────── */}
+      {isCritical && (
+        <g>
+          <rect
+            x={centerX - 60}
+            y={20}
+            width={120}
+            height={24}
+            fill={isFlyOff ? '#FEE2E2' : '#FEF3C7'}
+            rx={4}
+            opacity={0.9}
+          />
+          <text
+            x={centerX}
+            y={36}
+            fontSize={font(10)}
+            fill={isFlyOff ? KINEMATICS_COLORS.acceleration : '#D97706'}
+            textAnchor="middle"
+          >
+            {isFlyOff ? '⚠ 已离心' : '⚠ 临界警告'}
+          </text>
+        </g>
+      )}
+    </g>
+  )
+}
+
+// ─── 矢量箭头层 ────────────────────────────────────────────────────
+
+function VectorsLayer({
+  particleX,
+  particleY,
+  model,
+  gravity,
+  tension,
+  centripetal,
+  friction,
+  velocity,
+  font,
+}: {
+  particleX: number
+  particleY: number
+  model: 'cone-pendulum' | 'rotating-disk'
+  gravity: { dx: number; dy: number; magnitude: number; color: string }
+  tension: { dx: number; dy: number; magnitude: number; color: string }
+  centripetal: { dx: number; dy: number; magnitude: number; color: string }
+  friction: { dx: number; dy: number; magnitude: number; color: string }
+  velocity: { dx: number; dy: number; magnitude: number; color: string }
+  font: (size: number) => number
+}) {
+  const MIN_LEN = 35
+
+  return (
+    <g>
+      {gravity.magnitude > 5 && (
+        <VectorArrow
+          origin={{ x: particleX, y: particleY + 14 }}
+          direction={{ dx: 0, dy: 1 }}
+          magnitude={Math.max(gravity.magnitude, MIN_LEN)}
+          type="gravity"
+          refMagnitudes={{ gravity: 10 }}
+          label="mg"
+          labelOffset={{ x: -18, y: 0 }}
+          fontSize={font(9)}
+        />
+      )}
+
+      {tension.magnitude > 5 && (
+        <VectorArrow
+          origin={{ x: particleX, y: particleY }}
+          direction={{ dx: tension.dx, dy: tension.dy }}
+          magnitude={Math.max(tension.magnitude, MIN_LEN)}
+          type="forceNet"
+          refMagnitudes={{ forceNet: 10 }}
+          label="T"
+          labelOffset={{ x: 5, y: -8 }}
+          fontSize={font(9)}
+        />
+      )}
+
+      {centripetal.magnitude > 5 && (
+        <VectorArrow
+          origin={{ x: particleX, y: particleY }}
+          direction={{ dx: centripetal.dx, dy: centripetal.dy }}
+          magnitude={Math.max(centripetal.magnitude, MIN_LEN)}
+          type="forceNet"
+          refMagnitudes={{ forceNet: 10 }}
+          label="F_n"
+          labelOffset={{ x: 0, y: 20 }}
+          fontSize={font(9)}
+        />
+      )}
+
+      {model === 'rotating-disk' && friction.magnitude > 5 && (
+        <VectorArrow
+          origin={{ x: particleX, y: particleY }}
+          direction={{ dx: friction.dx, dy: friction.dy }}
+          magnitude={Math.max(friction.magnitude, MIN_LEN)}
+          type="appliedForce"
+          refMagnitudes={{ appliedForce: 10 }}
+          label="f"
+          labelOffset={{ x: 0, y: -18 }}
+          fontSize={font(9)}
+        />
+      )}
+
+      {velocity.magnitude > 5 && (
+        <VectorArrow
+          origin={{ x: particleX, y: particleY }}
+          direction={{ dx: velocity.dx, dy: velocity.dy }}
+          magnitude={Math.max(velocity.magnitude, MIN_LEN)}
+          type="velocity"
+          refMagnitudes={{ velocity: 2 }}
+          label="v"
+          labelOffset={{ x: 8, y: 8 }}
+          fontSize={font(9)}
+        />
+      )}
+    </g>
+  )
+}
+
+// ─── 物理标注 ───────────────────────────────────────────────────────
+
+function PhysicsAnnotations({
+  physics,
+  model,
+  centerX,
+  particleX,
+  particleY,
+  topY,
+  font,
+  trackRadius,
+}: {
+  physics: RotatingDiskPhysicsResult
+  model: 'cone-pendulum' | 'rotating-disk'
+  centerX: number
+  particleX: number
+  particleY: number
+  topY: number
+  font: (size: number) => number
+  trackRadius: number
+}) {
+  const { currentOmega, thetaDeg, centripetalForce, safetyFactor, omegaCrit } = physics
+
+  return (
+    <g>
+      {/* ─── 角速度标注 — displacement（蓝紫 #8B5CF6，同语义） */}
+      <text
+        x={centerX + trackRadius + 15}
+        y={particleY}
+        fontSize={font(11)}
+        fill={KINEMATICS_COLORS.displacement}
+        textAnchor="start"
+        dominantBaseline="middle"
+      >
+        ω = {currentOmega.toFixed(2)} rad/s
+      </text>
+
+      {/* ─── 圆锥摆：摆角标注 — forceNet（橙 #EA580C） */}
+      {model === 'cone-pendulum' && thetaDeg > 1 && (
+        <text
+          x={centerX}
+          y={topY + 15}
+          fontSize={font(11)}
+          fill={DYNAMICS_COLORS.forceNet}
+          textAnchor="middle"
+        >
+          θ = {thetaDeg.toFixed(1)}°
+        </text>
+      )}
+
+      {/* ─── 向心力标注 — forceNet（橙 #EA580C） */}
+      <text
+        x={centerX - trackRadius - 15}
+        y={particleY - 20}
+        fontSize={font(10)}
+        fill={DYNAMICS_COLORS.forceNet}
+        textAnchor="end"
+        dominantBaseline="middle"
+      >
+        F_n = {centripetalForce.toFixed(2)} N
+      </text>
+
+      {/* ─── 圆盘：摩擦力进度条 ─────────────────────── */}
+      {model === 'rotating-disk' && (
+        <g>
+          {/* 进度条背景 — reference 灰 */}
+          <rect
+            x={centerX - 50}
+            y={particleY + 30}
+            width={100}
+            height={8}
+            fill={CANVAS_COLORS.reference}
+            rx={4}
+          />
+          {/* 进度条填充 — 临界红/警告橙/安全绿 */}
+          <rect
+            x={centerX - 50}
+            y={particleY + 30}
+            width={Math.min(100, safetyFactor * 100)}
+            height={8}
+            fill={safetyFactor > 0.8 ? KINEMATICS_COLORS.acceleration : safetyFactor > 0.5 ? '#D97706' : '#16A34A'}
+            rx={4}
+          />
+          {/* 进度条标签 — annotation 灰 */}
+          <text
+            x={centerX}
+            y={particleY + 48}
+            fontSize={font(9)}
+            fill={CANVAS_COLORS.annotation}
+            textAnchor="middle"
+          >
+            f / f_max = {safetyFactor.toFixed(2)}
+          </text>
+        </g>
+      )}
+
+      {/* ─── 圆盘：临界角速度标注 — annotation 灰 */}
+      {model === 'rotating-disk' && omegaCrit < Infinity && (
+        <text
+          x={centerX}
+          y={particleY + 65}
+          fontSize={font(9)}
+          fill={CANVAS_COLORS.annotation}
+          textAnchor="middle"
+        >
+          ω_crit = {omegaCrit.toFixed(2)} rad/s
+        </text>
+      )}
+    </g>
+  )
+}

diff --git a/src/features/mechanics/circular/rotating-disk/components/RotatingDiskCharts.tsx b/src/features/mechanics/circular/rotating-disk/components/RotatingDiskCharts.tsx
