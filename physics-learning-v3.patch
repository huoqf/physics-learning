+/**
+ * src/utils/useViewport.ts
+ * 标准 Viewport 计算 Hook
+ *
+ * 与项目标准完全一致，返回 SVG transform 字符串
+ */
+import { useMemo } from 'react'
+import type { CanvasSize } from './useCanvasSize'
+
+export interface ViewportInfo {
+  /** 可视区域宽度（设计坐标） */
+  designWidth: number
+  /** 可视区域高度（设计坐标） */
+  designHeight: number
+  /**
+   * SVG g transform 字符串
+   * 用于 <AnimationSvgCanvas transform={vp.transform}>
+   */
+  transform: string
+  /** 实际可视宽度 px */
+  viewWidth: number
+  /** 实际可视高度 px */
+  viewHeight: number
+  /** 水平偏移 px（overlay 用） */
+  offsetX: number
+  /** 竖直偏移 px（overlay 用） */
+  offsetY: number
+}
+
+interface UseViewportOptions {
+  /** 视口设计宽度（通常来自 preset） */
+  designWidth: number
+  /** 视口设计高度（通常来自 preset） */
+  designHeight: number
+  /** 右侧遮挡 px */
+  overlayRight?: number
+  /** 左侧遮挡 px */
+  overlayLeft?: number
+  /** 顶部遮挡 px */
+  overlayTop?: number
+  /** 底部遮挡 px */
+  overlayBottom?: number
+}
+
+/**
+ * 根据容器尺寸和 overlay 计算 SVG transform
+ *
+ * @param canvasSize 容器尺寸（来自 useCanvasSize）
+ * @param options    视口选项
+ */
+export function useViewport(
+  canvasSize: CanvasSize,
+  options: UseViewportOptions
+): ViewportInfo {
+  const {
+    designWidth,
+    designHeight,
+    overlayRight = 0,
+    overlayLeft = 0,
+    overlayTop = 0,
+    overlayBottom = 0,
+  } = options
+
+  return useMemo(() => {
+    const { width, height } = canvasSize
+
+    // 计算缩放比（取宽高较小值保证内容完整）
+    const scaleX = (width - overlayLeft - overlayRight) / designWidth
+    const scaleY = (height - overlayTop - overlayBottom) / designHeight
+    const scale = Math.min(scaleX, scaleY)
+
+    // 计算居中偏移
+    const scaledW = designWidth * scale
+    const scaledH = designHeight * scale
+    const offsetX = overlayLeft + (width - overlayLeft - overlayRight - scaledW) / 2
+    const offsetY = overlayTop + (height - overlayTop - overlayBottom - scaledH) / 2
+
+    const transform = `translate(${offsetX.toFixed(2)},${offsetY.toFixed(2)}) scale(${scale.toFixed(4)})`
+
+    return {
+      designWidth,
+      designHeight,
+      transform,
+      viewWidth: width - overlayLeft - overlayRight,
+      viewHeight: height - overlayTop - overlayBottom,
+      offsetX,
+      offsetY,
+    }
+  }, [canvasSize, designWidth, designHeight, overlayLeft, overlayRight, overlayTop, overlayBottom])
+}

