@@ -0,0 +1,134 @@
+/**
+ * tests/physics/singleRod.test.ts
+ * 单杆电磁感应物理层单元测试
+ *
+ * ════════════════════════════════════════════════════════════════════════════
+ * 测试覆盖：
+ * • 初速度释放模式（scenario=0）：v→0 指数衰减
+ * • 恒力驱动模式（scenario=1）：v→v_m 指数收敛
+ * • 边界判定：导体棒到达导轨末端时状态归零
+ * • 电荷量积算：q = ∫I dt
+ * • 收尾速度公式：v_m = FR/(B²L²)
+ * • 时间常数：τ = mR/(B²L²)
+ * ════════════════════════════════════════════════════════════════════════════
+ */
+import { describe, it, expect } from 'vitest'
+import {
+  computeSingleRodConstants,
+  computeSingleRodStateAtTime,
+  generateSingleRodHistory,
+} from '@/physics/induction'
+
+describe('单杆电磁感应物理层', () => {
+  // ─── 基础参数 ─────────────────────────────────────────────────────
+  const BASE_PARAMS = {
+    scenario: 1,
+    B: 1.0,
+    L: 0.5,
+    R: 1.0,
+    m: 0.2,
+    F_ext: 2.0,
+  }
+
+  describe('computeSingleRodConstants', () => {
+    it('恒力驱动：收尾速度 v_m = FR/(B²L²)', () => {
+      const { v_m } = computeSingleRodConstants(1, 2.0, 1.0, 0.5, 1.0, 0.2)
+      // v_m = F·R / (B²·L²) = 2·1 / (1·0.25) = 2 / 0.25 = 8 m/s
+      expect(v_m).toBeCloseTo(8.0, 4)
+    })
+
+    it('恒力驱动：时间常数 τ = mR/(B²L²)', () => {
+      const { tau } = computeSingleRodConstants(1, 2.0, 1.0, 0.5, 1.0, 0.2)
+      // τ = m·R / (B²·L²) = 0.2·1 / 0.25 = 0.8 s
+      expect(tau).toBeCloseTo(0.8, 4)
+    })
+
+    it('初速度释放：收尾速度 v_m = 0（最终静止）', () => {
+      const { v_m } = computeSingleRodConstants(0, 5.0, 1.0, 0.5, 1.0, 0.2)
+      expect(v_m).toBeCloseTo(0, 4)
+    })
+
+    it('R=0 时，时间常数 τ = Infinity（理想无电阻）', () => {
+      const { tau } = computeSingleRodConstants(1, 2.0, 1.0, 0.5, 0, 0.2)
+      expect(Number.isFinite(tau)).toBe(false)
+    })
+  })
+
+  describe('computeSingleRodStateAtTime', () => {
+    it('恒力驱动：t=0 时速度为零，加速度为正', () => {
+      const state = computeSingleRodStateAtTime(0, BASE_PARAMS)
+      expect(state.v).toBeCloseTo(0, 4)
+      expect(state.a).toBeGreaterThan(0)
+    })
+
+    it('恒力驱动：t→∞ 时速度收敛到 v_m', () => {
+      const state = computeSingleRodStateAtTime(100, BASE_PARAMS)
+      const { v_m } = computeSingleRodConstants(1, 2.0, 1.0, 0.5, 1.0, 0.2)
+      expect(state.v).toBeCloseTo(v_m, 1)
+    })
+
+    it('初速度释放：速度随时间指数衰减', () => {
+      const v0Params = { scenario: 0, B: 1.0, L: 0.5, R: 1.0, m: 0.2, F_ext: 5.0 }
+      const state0 = computeSingleRodStateAtTime(0, v0Params)
+      const state1 = computeSingleRodStateAtTime(1, v0Params)
+      const state2 = computeSingleRodStateAtTime(2, v0Params)
+      // 速度应单调递减
+      expect(state2.v).toBeLessThan(state1.v)
+      expect(state1.v).toBeLessThan(state0.v)
+      // 初速度应为 F_ext（v₀）
+      expect(state0.v).toBeCloseTo(5.0, 4)
+    })
+
+    it('感应电动势 E = BLv', () => {
+      const state = computeSingleRodStateAtTime(1, BASE_PARAMS)
+      const expectedEMF = BASE_PARAMS.B * BASE_PARAMS.L * Math.abs(state.v)
+      expect(state.EMF).toBeCloseTo(expectedEMF, 4)
+    })
+
+    it('感应电流 I = E/R', () => {
+      const state = computeSingleRodStateAtTime(1, BASE_PARAMS)
+      const expectedI = state.EMF / BASE_PARAMS.R
+      expect(state.I).toBeCloseTo(expectedI, 4)
+    })
+
+    it('安培力方向：始终阻碍运动（向左为负）', () => {
+      const state = computeSingleRodStateAtTime(1, BASE_PARAMS)
+      // 恒力驱动时速度为正，安培力应为负（向左）
+      expect(state.F_A).toBeLessThan(0)
+    })
+
+    it('电荷量非负', () => {
+      const state = computeSingleRodStateAtTime(2, BASE_PARAMS)
+      expect(state.charge).toBeGreaterThanOrEqual(0)
+    })
+  })
+
+  describe('generateSingleRodHistory', () => {
+    it('生成指定数量的采样点', () => {
+      const history = generateSingleRodHistory(5.0, BASE_PARAMS, 50)
+      expect(history.vtPoints).toHaveLength(51)  // 包含 t=0 和 t=T_max
+      expect(history.itPoints).toHaveLength(51)
+      expect(history.energyPoints).toHaveLength(51)
+    })
+
+    it('采样点时间单调递增', () => {
+      const { vtPoints } = generateSingleRodHistory(5.0, BASE_PARAMS, 20)
+      for (let i = 1; i < vtPoints.length; i++) {
+        expect(vtPoints[i].t).toBeGreaterThan(vtPoints[i - 1].t)
+      }
+    })
+
+    it('v-t 图速度范围合理（不超过理论最大值 1.15×）', () => {
+      const { vtPoints, vMax } = generateSingleRodHistory(5.0, BASE_PARAMS, 50)
+      const actualMax = Math.max(...vtPoints.map(p => Math.abs(p.v)))
+      expect(actualMax).toBeLessThanOrEqual(vMax)
+    })
+
+    it('I-t 图电流非负（绝对值）', () => {
+      const { itPoints } = generateSingleRodHistory(5.0, BASE_PARAMS, 50)
+      for (const pt of itPoints) {
+        expect(pt.I).toBeGreaterThanOrEqual(0)
+      }
+    })
+  })
+})
