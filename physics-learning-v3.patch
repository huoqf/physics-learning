@@ -0,0 +1,256 @@
+/**
+ * src/physics/induction/singleRod.ts
+ * 单杆电磁感应物理计算 — 纯 TypeScript，无副作用，可序列化
+ *
+ * ════════════════════════════════════════════════════════════════════════════
+ * 设计原则（铁律 2 物理层纯函数）
+ * • 无 DOM / React / window 依赖
+ * • 所有数据结构可序列化（兼容 IndexedDB 持久化）
+ * • 有 JSDoc + 单位注释
+ * ════════════════════════════════════════════════════════════════════════════
+ *
+ * @description
+ * 模式 0（初速度释放）：m·dv/dt = −(B²L²/R)·v → v(t)=v₀·e^{−t/τ}
+ * 模式 1（恒力驱动）：  m·dv/dt = F − (B²L²/R)·v → v(t)=v_m·(1−e^{−t/τ})
+ *
+ * 关键物理量：
+ * • 感应电动势 E = BLv
+ * • 感应电流   I = E/R = BLv/R
+ * • 安培力     F_A = BIL = B²L²v/R
+ * • 时间常数   τ = mR/(B²L²)
+ * • 收尾速度   v_m = FR/(B²L²) [恒力模式] / 0 [初速模式]
+ * • 累积电荷量 q = ∫₀ᵗ I(τ)dτ
+ */
+
+export interface SingleRodParams {
+  scenario: number    // 0=初速度释放, 1=恒力驱动
+  B: number           // 磁感应强度 T
+  L: number           // 导轨间距 m
+  R: number           // 总电阻 Ω
+  m: number           // 导体棒质量 kg
+  F_ext: number       // 外力/初速度参数（N 或 m/s）
+  initialX?: number   // 初始位移 m，默认 0
+}
+
+export interface SingleRodState {
+  /** 速度 m/s（向右为正） */
+  v: number
+  /** 位移 m */
+  x: number
+  /** 加速度 m/s²（向右为正） */
+  a: number
+  /** 感应电流 A（向上为正） */
+  I: number
+  /** 感应电动势 V */
+  EMF: number
+  /** 安培力 N（向左为负） */
+  F_A: number
+  /** 累积电荷量 C */
+  charge: number
+  /** 外力做功 J */
+  energyW: number
+  /** 焦耳热 J */
+  energyQ: number
+  /** 收尾速度 m/s */
+  v_m: number
+  /** 时间常数 s */
+  tau: number
+  /** 是否到达边界 */
+  hasHitLimit: boolean
+}
+
+export interface SingleRodConstants {
+  /** 收尾速度 m/s */
+  v_m: number
+  /** 时间常数 s */
+  tau: number
+  /** 初始加速度 m/s² */
+  a_0: number
+  /** 阻力系数 k = B²L²/R */
+  k: number
+}
+
+// ─── 边界与常量 ─────────────────────────────────────────────────────────────
+
+/** 物理世界边界（m）- 2000m 足够大，确保在仿真时长内不会触达 */
+const WORLD_X_MIN = -0.5
+const WORLD_X_MAX = 2000.0
+
+// ─── 核心计算函数 ─────────────────────────────────────────────────────────
+
+/**
+ * 计算单杆电磁感应的常数值（收尾速度、时间常数、初始加速度）
+ *
+ * @param scenario 启动模式（0=初速释放, 1=恒力驱动）
+ * @param F_ext    外力(N) 或初速度(m/s)
+ * @param B        磁感应强度 T
+ * @param L        导轨间距 m
+ * @param R        总电阻 Ω
+ * @param m        导体棒质量 kg
+ */
+export function computeSingleRodConstants(
+  scenario: number,
+  F_ext: number,
+  B: number,
+  L: number,
+  R: number,
+  m: number
+): SingleRodConstants {
+  const k = R > 0 ? (B * B * L * L) / R : 0  // 阻力系数
+  const tau = k > 0 ? m / k : Infinity        // 时间常数
+
+  let v_m: number
+  let a_0: number
+
+  if (scenario === 0) {
+    // 初速度释放：v(t) = v₀·e^{−t/τ}，最终静止
+    v_m = 0
+    a_0 = k > 0 ? -(F_ext / m) * (B * B * L * L / R) : 0
+  } else {
+    // 恒力驱动：v(t) = v_m·(1−e^{−t/τ})，收尾匀速
+    v_m = k > 0 ? (F_ext * R) / (B * B * L * L) : Infinity
+    a_0 = k > 0 ? (F_ext / m) * (B * B * L * L / R) : F_ext / m
+  }
+
+  return { v_m, tau, a_0, k }
+}
+
+/**
+ * 计算单杆在任意时刻的物理状态
+ *
+ * @param t        当前时刻 s
+ * @param params   单杆物理参数
+ * @returns 瞬时物理状态
+ */
+export function computeSingleRodStateAtTime(
+  t: number,
+  params: SingleRodParams
+): SingleRodState {
+  const { scenario, B, L, R, m, F_ext, initialX = 0 } = params
+
+  const k = R > 0 ? (B * B * L * L) / R : 0
+  const tau = k > 0 ? m / k : Infinity
+
+  // 计算瞬时速度与加速度（解析解）
+  let v: number, a: number, x: number
+  let v_m: number
+
+  if (scenario === 0) {
+    // 初速度释放：v(t) = v₀·e^{−t/τ}
+    const v_0 = F_ext
+    v = v_0 * Math.exp(-t / tau)
+    a = -(v_0 / tau) * Math.exp(-t / tau)
+    // 位移积分：x(t) = v_0·τ·(1−e^{−t/τ})
+    x = initialX + v_0 * tau * (1 - Math.exp(-t / tau))
+    v_m = 0
+  } else {
+    // 恒力驱动：v(t) = v_m·(1−e^{−t/τ})
+    v_m = k > 0 ? (F_ext * R) / (B * B * L * L) : F_ext * 1e10
+    v = v_m * (1 - Math.exp(-t / tau))
+    a = (v_m / tau) * Math.exp(-t / tau)
+    // 位移积分：x(t) = v_m·(t − τ·(1−e^{−t/τ}))
+    x = initialX + v_m * (t - tau * (1 - Math.exp(-t / tau)))
+  }
+
+  // 物理量计算
+  const EMF = B * L * Math.abs(v)
+  const I = R > 0 ? EMF / R : 0
+  // 安培力方向：始终阻碍运动（向左）
+  const F_A = scenario === 0
+    ? -k * Math.abs(v)  // 初速释放：向左减速
+    : -k * v             // 恒力驱动：向左阻碍加速
+
+  // 累积电荷量 q = ∫₀ᵗ I(τ)dτ
+  let charge: number
+  if (scenario === 0) {
+    const v_0 = F_ext
+    const q_coef = (v_0 * B * L) / R
+    charge = q_coef * tau * (1 - Math.exp(-t / tau))
+  } else {
+    const q_coef = (v_m * B * L) / R
+    charge = q_coef * (t - tau * (1 - Math.exp(-t / tau)))
+  }
+
+  // 能量计算
+  const energyW = scenario === 1 ? F_ext * x : 0
+  // 焦耳热：Q = ∫ I²R dt ≈ I²R·t（瞬时功率积分）
+  const energyQ = I * I * R * t
+
+  // 边界判定
+  const hasHitLimit = v >= 0 ? x >= WORLD_X_MAX : x <= WORLD_X_MIN
+
+  return {
+    v: hasHitLimit ? 0 : v,
+    x: Math.max(WORLD_X_MIN, Math.min(WORLD_X_MAX, x)),
+    a: hasHitLimit ? 0 : a,
+    I: hasHitLimit ? 0 : I,
+    EMF: hasHitLimit ? 0 : EMF,
+    F_A: hasHitLimit ? 0 : F_A,
+    charge: hasHitLimit ? charge : 0,
+    energyW: hasHitLimit ? energyW : 0,
+    energyQ: hasHitLimit ? energyQ : 0,
+    v_m: scenario === 0 ? 0 : v_m,
+    tau,
+    hasHitLimit,
+  }
+}
+
+/**
+ * 生成历史采样点序列（用于图表渲染）
+ *
+ * @param T_max    最大采样时间 s
+ * @param params   单杆物理参数
+ * @param count    采样点数，默认 100
+ */
+export function generateSingleRodHistory(
+  T_max: number,
+  params: SingleRodParams,
+  count = 100
+): {
+  vtPoints: Array<{ t: number; v: number }>
+  itPoints: Array<{ t: number; I: number }>
+  energyPoints: Array<{ t: number; W: number; Q: number; E: number }>
+  chargePoints: Array<{ t: number; q: number }>
+  vMax: number
+  IMax: number
+  energyMax: number
+} {
+  const vtPoints: Array<{ t: number; v: number }> = []
+  const itPoints: Array<{ t: number; I: number }> = []
+  const energyPoints: Array<{ t: number; W: number; Q: number; E: number }> = []
+  const chargePoints: Array<{ t: number; q: number }> = []
+
+  let vMax = 1.0
+  let IMax = 1.0
+  let energyMax = 1.0
+
+  for (let i = 0; i <= count; i++) {
+    const tVal = (i / count) * T_max
+    const state = computeSingleRodStateAtTime(tVal, params)
+
+    vtPoints.push({ t: tVal, v: state.v })
+    itPoints.push({ t: tVal, I: state.I })
+    energyPoints.push({
+      t: tVal,
+      W: state.energyW,
+      Q: state.energyQ,
+      E: state.energyW - state.energyQ,
+    })
+    chargePoints.push({ t: tVal, q: state.charge })
+
+    if (Math.abs(state.v) > vMax) vMax = Math.abs(state.v)
+    if (Math.abs(state.I) > IMax) IMax = Math.abs(state.I)
+    const totalE = Math.max(state.energyW, state.energyQ)
+    if (totalE > energyMax) energyMax = totalE
+  }
+
+  return {
+    vtPoints,
+    itPoints,
+    energyPoints,
+    chargePoints,
+    vMax: vMax * 1.15,
+    IMax: IMax * 1.15,
+    energyMax: energyMax * 1.25,
+  }
+}

