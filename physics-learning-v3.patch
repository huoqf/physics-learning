+/**
+ * src/stores/index.ts
+ * 全局动画状态 Store（铁律 3：动画状态统一管理）
+ */
+import { create } from 'zustand'
+
+export interface AnimationStore {
+  // ─── 动画状态 ───────────────────────────────────────
+  /** 当前时间 s */
+  time: number
+  /** 是否正在播放 */
+  isPlaying: boolean
+  /** 播放速率 */
+  playbackRate: number
+  /** 总时长 s */
+  duration: number
+
+  // ─── 参数状态 ───────────────────────────────────────
+  /** 当前动画参数（由注册表 defaultParams 初始化） */
+  params: Record<string, unknown>
+
+  // ─── 操作方法 ───────────────────────────────────────
+  setTime: (t: number) => void
+  setIsPlaying: (playing: boolean) => void
+  setPlaybackRate: (rate: number) => void
+  setParams: (params: Record<string, unknown>) => void
+  updateParam: (key: string, value: unknown) => void
+  reset: () => void
+}
+
+const DEFAULT_STATE = {
+  time: 0,
+  isPlaying: false,
+  playbackRate: 1.0,
+  duration: 10,
+  params: {},
+}
+
+export const useAnimationStore = create<AnimationStore>((set) => ({
+  ...DEFAULT_STATE,
+
+  setTime: (t) => set({ time: Math.max(0, Math.min(t, DEFAULT_STATE.duration)) }),
+  setIsPlaying: (playing) => set({ isPlaying: playing }),
+  setPlaybackRate: (rate) => set({ playbackRate: Math.max(0.1, Math.min(rate, 4)) }),
+  setParams: (params) => set({ params }),
+  updateParam: (key, value) =>
+    set((s) => ({ params: { ...s.params, [key]: value } })),
+  reset: () => set(DEFAULT_STATE),
+}))

