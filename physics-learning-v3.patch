+ * 物理量颜色语义映射 — Canvas / SVG 内唯一颜色来源
+ */
+/**
+ * 将 HEX 颜色转换为带透明度的 rgba 字符串
+ *
+ * @param hex   HEX 颜色字符串（支持 #RGB 或 #RRGGBB 格式）
+ * @param alpha 透明度 [0, 1]
+ */
+export function withAlpha(hex: string, alpha: number): string {
+  const clean = hex.replace('#', '')
+  let r: number, g: number, b: number
+
+  if (clean.length === 3) {
+    // #RGB 格式：每位重复两次转为 #RRGGBB
+    r = parseInt(clean[0] + clean[0], 16)
+    g = parseInt(clean[1] + clean[1], 16)
+    b = parseInt(clean[2] + clean[2], 16)
+  } else if (clean.length === 6) {
+    // #RRGGBB 格式
+    r = parseInt(clean.substring(0, 2), 16)
+    g = parseInt(clean.substring(2, 4), 16)
+    b = parseInt(clean.substring(4, 6), 16)
+  } else {
+    return hex
+  }
+
+  return `rgba(${r}, ${g}, ${b}, ${alpha})`
+}
+
+// 运动学颜色
+export const KINEMATICS_COLORS = {
+  velocity: '#2563EB',
+  velocityX: '#3B82F6',
+  velocityY: '#60A5FA',
+  acceleration: '#DC2626',
+  accelerationX: '#EF4444',
+  accelerationY: '#F87171',
+  displacement: '#8B5CF6',
+} as const
+
+// 动力学颜色
+export const DYNAMICS_COLORS = {
+  forceNet: '#EA580C',
+  forceNetArrow: '#C2410C',
+  gravity: '#166534',
+  normalForce: '#0284C7',
+  friction: '#B45309',
+  elasticForce: '#DB2777',
+  tension: '#8B5CF6',
+  appliedForce: '#1E3A8A',
+} as const
+
+// 能量与动量颜色
+export const ENERGY_COLORS = {
+  kineticEnergy: '#06B6D4',
+  potentialEnergy: '#7C3AED',
+  internalEnergy: '#B91C1C',
+  heatLoss: '#EF4444',
+  work: '#84CC16',
+  power: '#D97706',
