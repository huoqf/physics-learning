+ * 圆盘与圆锥摆物理计算 — 纯 TypeScript，无副作用，可序列化
+ *
+ * ════════════════════════════════════════════════════════════════════════════
+ * 设计原则（铁律 2 物理层纯函数）
+ * • 无 DOM / React / window 依赖
+ * • 所有数据结构可序列化
+ * • 有 JSDoc + 单位注释
+ *
+ * 两种模型物理方程：
+ *
+ * 【模型 A：圆锥摆】
+ * • 摆角 θ：绳与竖直方向夹角
+ * • 旋转半径 r = L·sinθ
+ * • 竖直方向力平衡：T·cosθ = mg
+ * • 水平向心力：T·sinθ = m·ω²·r
+ * • 推导：tanθ = ω²·r/g = ω²·L·sinθ/g
+ * • 临界：当 ω²·L > g 时，cosθ = g/(ω²·L)
+ *
+ * 【模型 B：旋转圆盘】
+ * • 物体在旋转圆盘上随盘转动
+ * • 静摩擦力提供向心力：f = m·ω²·r
+ * • 最大静摩擦力：f_max = μ·mg
+ * • 临界角速度：ω_crit = √(μ·g/r)
+ * • 当 ω > ω_crit 时，物体做离心运动滑出圆盘
+ *
+ * ════════════════════════════════════════════════════════════════════════════
+ */
+
+// ─── 类型定义 ─────────────────────────────────────────────────────────
+
+export type RotatingDiskModel = 'cone-pendulum' | 'rotating-disk'  // 圆锥摆 / 圆盘
+
+export interface RotatingDiskParams {
+  /** 模型类型 */
+  model: RotatingDiskModel
+  /** 角速度 rad/s */
+  omega: number
+  /** 绳长/圆盘半径 m */
+  L: number
+  /** 圆锥摆：摆长 L（同时也是旋转半径 r 的函数） */
+  ropeLength?: number
+  /** 旋转圆盘：半径 r m */
+  radius?: number
+  /** 最大静摩擦系数（圆盘模型） */
+  mu: number
+  /** 重力加速度 m/s²（默认 9.8） */
+  g: number
+  /** 物体质量 kg */
+  m: number
+}
+
+export interface RotatingDiskState {
+  // ─── 通用量 ─────────────────────────────────────────
+  /** 角速度 rad/s */
+  omega: number
+  /** 向心力 N */
+  centripetalForce: number
+  /** 周期 s */
+  period: number
+  /** 线速度 m/s */
+  linearVelocity: number
+
+  // ─── 圆锥摆专有量 ───────────────────────────────────
+  /** 摆角 rad */
+  theta: number
+  /** 摆角 °（用于显示） */
+  thetaDeg: number
+  /** 旋转半径 m */
+  rotationRadius: number
+  /** 绳拉力 N */
+  tension: number
+
+  // ─── 圆盘专有量 ─────────────────────────────────────
+  /** 所需静摩擦力 N */
+  requiredFriction: number
+  /** 最大静摩擦力 N */
+  maxFriction: number
+  /** 静摩擦力占比 [0, 1] */
+  frictionRatio: number
+  /** 是否达到临界（即将/已经离心） */
+  isCritical: boolean
+  /** 临界角速度 rad/s */
+  omegaCrit: number
+
+  // ─── 状态标志 ───────────────────────────────────────
+  /** 物体是否已离心（滑出圆盘/摆绳已失去张力） */
+  isFlyOff: boolean
+  /** 安全因子（摩擦力 / 最大摩擦，用于进度条） */
+  safetyFactor: number
+}
+
+export interface RotatingDiskConstants {
+  /** 模型类型 */
+  model: RotatingDiskModel
+  /** 临界角速度 rad/s */
+  omegaCrit: number
+  /** 最大向心力（圆锥摆临界时） N */
+  maxCentripetalForce: number
+  /** 绳长或半径（统一参数） */
+  L: number
+}
+
+// ─── 物理计算函数 ───────────────────────────────────────────────────
+
+/**
+ * 计算圆盘/圆锥摆的常数值
+ *
+ * @param params 物理参数
+ */
+export function computeRotatingDiskConstants(
+  params: RotatingDiskParams
+): RotatingDiskConstants {
+  const { model, omega, L, mu = 0.5, g = 9.8 } = params
+  const g_default = g || 9.8
+
+  if (model === 'rotating-disk') {
+    // 圆盘模型：ω_crit = √(μg/r)
+    const r = params.radius ?? L
+    const omegaCrit = r > 0 ? Math.sqrt((mu * g_default) / r) : Infinity
+    const maxForce = mu * params.m * g_default
+    return { model, omegaCrit, maxCentripetalForce: maxForce, L: r }
+  } else {
+    // 圆锥摆模型：无明显临界（理想模型）
+    // 最大安全角速度（cosθ > 0 的极限）
+    const omegaCrit = Math.sqrt(2 * g_default / L)  // cosθ = 0.5 时
+    return { model, omegaCrit, maxCentripetalForce: Infinity, L }
+  }
+}
+
+/**
+ * 计算任意时刻的物理状态
+ *
+ * @param t 当前时刻 s（当前版本为静态计算，ω 不随时间变化）
+ * @param params 物理参数
+ */
+export function computeRotatingDiskStateAtTime(
+  t: number,
+  params: RotatingDiskParams
+): RotatingDiskState {
+  const {
+    model,
+    omega = 0,
+    L = 1.0,
+    mu = 0.5,
+    g = 9.8,
+    m = 1.0,
+  } = params
+
+  const g_ = g || 9.8
+
+  // ─── 通用量计算 ──────────────────────────────────────
+  const period = omega > 0 ? (2 * Math.PI) / omega : Infinity
+  const linearVelocity = omega * L  // 使用 L 作为等效半径
+
+  // ─── 向心力（两种模型共用）───────────────────────────
+  const centripetalForce = m * omega * omega * L
+
+  if (model === 'cone-pendulum') {
+    // ─── 圆锥摆模型 ────────────────────────────────────
+    // tanθ = ω²·L·sinθ/g → cosθ = g/(ω²·L)
+
+    // 边界处理：omega=0 时物体静止，theta=0，rotationRadius=0
+    if (omega <= 0) {
+      return {
+        omega,
+        centripetalForce,
+        period: Infinity,
+        linearVelocity: 0,
+        theta: 0,
+        thetaDeg: 0,
+        rotationRadius: 0,
+        tension: m * g_,  // 静止时绳拉力 = mg（竖直方向平衡）
+        requiredFriction: 0,
+        maxFriction: 0,
+        frictionRatio: 0,
+        isCritical: false,
+        omegaCrit: Math.sqrt(2 * g_ / L),
+        isFlyOff: false,
+        safetyFactor: 0,
+      }
+    }
+
+    const sinOmegaSqL = omega * omega * L
+
+    let theta: number, rotationRadius: number, tension: number
+
+    if (sinOmegaSqL <= g_) {
+      // 正常状态：cosθ = g/(ω²·L)，θ ∈ [0, 90°)
+      // clamp cosTheta ∈ [0,1] 防止浮点误差导致 acos(NaN)
+      const cosTheta = Math.min(1, Math.max(0, g_ / sinOmegaSqL))
+      theta = Math.acos(cosTheta)
+      rotationRadius = L * Math.sin(theta)
+      tension = m * g_ / Math.max(cosTheta, 1e-10)  // T = mg / cosθ（避免除零）
+    } else {
+      // ω²·L > g：θ → 90°，旋转半径趋近 L
+      theta = Math.PI / 2 - 0.1  // 接近垂直
+      rotationRadius = L * Math.sin(theta)
+      tension = m * omega * omega * L  // T ≈ mω²L
+    }
+
+    const thetaDeg = (theta * 180) / Math.PI
+
+    return {
+      omega,
+      centripetalForce,
+      period,
+      linearVelocity,
+      theta,
+      thetaDeg,
+      rotationRadius,
+      tension,
+      // 圆盘专有量设为 0
+      requiredFriction: 0,
+      maxFriction: 0,
+      frictionRatio: 0,
+      isCritical: false,
+      omegaCrit: Math.sqrt(2 * g_ / L),
+      isFlyOff: false,
+      safetyFactor: 0,
+    }
+  } else {
+    // ─── 旋转圆盘模型 ──────────────────────────────────
+    const r = params.radius ?? L
+    const requiredFriction = m * omega * omega * r
+    const maxFriction = mu * m * g_
+    const frictionRatio = maxFriction > 0 ? requiredFriction / maxFriction : 0
+
+    // 临界角速度
+    const omegaCrit = r > 0 ? Math.sqrt((mu * g_) / r) : Infinity
+
+    // 是否达到临界（摩擦力占比 > 1 或 ω > ω_crit）
+    const isCritical = frictionRatio >= 1.0 || omega >= omegaCrit
+
+    // 是否已离心
+    const isFlyOff = omega > omegaCrit && omegaCrit < Infinity
+
+    // 安全因子（用于 UI 进度条，0-1 表示摩擦力占比）
+    const safetyFactor = Math.min(1, Math.max(0, frictionRatio))
+
+    return {
+      omega,
+      centripetalForce,
+      period,
+      linearVelocity: omega * r,
+      // 圆锥摆专有量设为 0
+      theta: 0,
+      thetaDeg: 0,
+      rotationRadius: 0,
+      tension: 0,
+      requiredFriction,
+      maxFriction,
+      frictionRatio,
+      isCritical,
+      omegaCrit,
+      isFlyOff,
+      safetyFactor,
+    }
+  }
+}
+
+/**
+ * 生成历史采样点序列（用于图表渲染）
+ *
+ * @param omegaMax 最大角速度 rad/s
+ * @param params 物理参数
+ * @param count 采样点数
+ */
+export function generateRotatingDiskHistory(
+  omegaMax: number,
+  params: RotatingDiskParams,
+  count = 100
+): {
+  forcePoints: Array<{ omega: number; force: number }>
+  anglePoints: Array<{ omega: number; angle: number }>
+  frictionPoints: Array<{ omega: number; friction: number; maxFriction: number }>
+  omegaMax: number
+  forceMax: number
+} {
+  const { model, L, mu = 0.5, g = 9.8, m = 1.0 } = params
+  const g_ = g || 9.8
+
+  const forcePoints: Array<{ omega: number; force: number }> = []
+  const anglePoints: Array<{ omega: number; angle: number }> = []
+  const frictionPoints: Array<{ omega: number; friction: number; maxFriction: number }> = []
+
+  let forceMax = 1.0
+
+  for (let i = 0; i <= count; i++) {
+    const omegaVal = (i / count) * omegaMax
+
+    // 向心力
+    const force = m * omegaVal * omegaVal * L
+    forcePoints.push({ omega: omegaVal, force })
+    if (force > forceMax) forceMax = force
+
+    // 圆锥摆：摆角
+    if (model === 'cone-pendulum') {
+      const sinOmegaSqL = omegaVal * omegaVal * L
+      let angleDeg = 0
+      if (sinOmegaSqL > 0) {
+        const cosTheta = Math.min(1, g_ / sinOmegaSqL)
+        const theta = Math.acos(cosTheta)
+        angleDeg = (theta * 180) / Math.PI
+      }
+      anglePoints.push({ omega: omegaVal, angle: angleDeg })
+    }
+
+    // 圆盘：摩擦力（clamp 至 maxFriction，物理上摩擦力不会超过最大静摩擦）
+    if (model === 'rotating-disk') {
+      const r = params.radius ?? L
+      const requiredFriction = m * omegaVal * omegaVal * r
+      const maxFriction = mu * m * g_
+      // 摩擦力被最大静摩擦钳制（真实物理行为）
+      const friction = Math.min(requiredFriction, maxFriction)
+      frictionPoints.push({ omega: omegaVal, friction, maxFriction })
+    }
+  }
+
+  return {
+    forcePoints,
+    anglePoints,
+    frictionPoints,
+    omegaMax,
+    forceMax: forceMax * 1.2,
+  }
+}

