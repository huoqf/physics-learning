+/**
+ * src/theme/spacing.ts
+ * 画布预设尺寸常量
+ *
+ * 与项目 CANVAS_PRESETS 完全一致
+ * 用于 useAnimationViewport({ preset: CANVAS_PRESETS.xxx })
