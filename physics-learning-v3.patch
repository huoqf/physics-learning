+/**
+ * src/features/mechanics/circular/rotating-disk/RotatingDiskPage.tsx
+ * 圆盘与圆锥摆模型 — 主屏入口（薄壳）
+ *
+ * ════════════════════════════════════════════════════════════════════════════
+ * 布局：splitH 左右分区
+ * • 左侧 (flex-1)：AnimationSvgCanvas + 物理视界场景
+ * • 右侧 (w-0, min-w-[280px])：图表面板
+ *
+ * 合规要点（铁律 1/3/6）：
+ * • 铁律 1-7：useAnimationViewport({ preset: CANVAS_PRESETS.splitH }) + AnimationSvgCanvas
+ * • 铁律 1-8：三图表在 HTML 层（右侧面板内），无 foreignObject
+ * • 铁律 3：页面薄壳化，无业务逻辑
+ * • 铁律 6：左屏参数由注册表 controlMeta/paramMeta 提供（AnimationPage 处理）
+ * ════════════════════════════════════════════════════════════════════════════
+ */
+import React, { useEffect, useRef } from 'react'
+import { useAnimationStore } from '@/stores'
+import { useShallow } from 'zustand/react/shallow'
+import { useAnimationViewport } from '@/hooks'
+import { CANVAS_PRESETS } from '@/theme/spacing'
+
+import { AnimationSvgCanvas } from '@/components/Layout'
+import { RotatingDiskScene, RotatingDiskCharts, useRotatingDiskPhysics } from './'
+
+export default function RotatingDiskPage() {
+  // ─── 从动画 Store 读取状态 ────────────────────────────────────────
+  const { params, time, setIsPlaying } = useAnimationStore(
+    useShallow(s => ({
+      params: s.params,
+      time: s.time,
+      setIsPlaying: s.setIsPlaying,
+    }))
+  )
+
+  const {
+    model = 'cone-pendulum',
+    omega = 2.0,
+    L = 0.5,
+    mu = 0.5,
+    g = 9.8,
+    m = 1.0,
+  } = params as Record<string, unknown>
+
+  // 圆盘模型的半径（统一用 L 参数）
+  const radius = L as number
+
+  // ─── Viewport（铁律 1-7 新标准路径）───────────────────────────────
+  // splitH: { width: 350, height: 650 } — 左右分区
+  const { containerRef, canvasSize, vp } = useAnimationViewport({
+    preset: CANVAS_PRESETS.splitH,
+  })
+
+  // ─── 物理层 Hook ──────────────────────────────────────────────────
+  const physics = useRotatingDiskPhysics(
+    {
+      model: model as 'cone-pendulum' | 'rotating-disk',
+      omega: omega as number,
+      L: L as number,
+      radius,
+      mu: mu as number,
+      g: g as number,
+      m: m as number,
+    },
+    canvasSize,
+    time
+  )
+
+  // ─── 离心处理 ─────────────────────────────────────────────────────
+  const prevFlyOff = useRef(false)
+  useEffect(() => {
+    if (physics.isFlyOff && !prevFlyOff.current) {
+      setIsPlaying(false)
+    }
+    prevFlyOff.current = physics.isFlyOff
+  }, [physics.isFlyOff, setIsPlaying])
+
+  // ─── 主屏布局（splitH 左右分区）───────────────────────────────────
+  return (
+    // ✅ splitH 左右分区：flex-row
+    <div className="relative w-full h-full flex flex-row gap-2 p-1">
+      {/* ─── 左侧：物理视界（flex-1）────────────────────── */}
+      <div className="flex-1 min-w-0 min-h-0">
+        <AnimationSvgCanvas
+          containerRef={containerRef}
+          transform={vp.transform}
+          className="bg-neutral-50 rounded-xl overflow-hidden h-full"
+        >
+          {/* 场景内容使用设计坐标（0..350 / 0..650），由 vp.transform 缩放 */}
+          <RotatingDiskScene
+            physics={physics}
+            model={model as 'cone-pendulum' | 'rotating-disk'}
+            canvasSize={canvasSize}
+          />
+        </AnimationSvgCanvas>
+      </div>
+
+      {/* ─── 右侧：图表面板（固定宽度）─────────────────── */}
+      {/* ✅ 铁律 1-8：三图表在 HTML flex 纵向堆叠，无 foreignObject */}
+      <div className="w-0 min-w-[280px] h-full min-h-0" style={{ minWidth: 280 }}>
+        <RotatingDiskCharts
+          physics={physics}
+          model={model as 'cone-pendulum' | 'rotating-disk'}
+          currentOmega={physics.currentOmega}
+        />
+      </div>
+    </div>
+  )
+}

