--- /dev/null
+++ b/src/features/electromagnetism/induction/single-rod/hooks/useSingleRodPhysics.ts
@@ -0,0 +1,257 @@
+/**
+ * src/features/electromagnetism/induction/single-rod/hooks/useSingleRodPhysics.ts
+ * 单杆电磁感应物理 Hook — 封装 RK4 + 图表数据生成
+ *
+ * @description
+ * 遵循项目规范：
+ * • 纯函数封装，无副作用
+ * • 图表数据预计算（useMemo 缓存）
+ * • 坐标转换通过 physicsToCanvasWithOrigin
+ * • 布局常量命名（CANVAS_PRESETS.splitV = 700×325）
+ */
+import { useMemo } from 'react'
+import {
+  computeSingleRodConstants,
+  computeSingleRodStateAtTime,
+  generateSingleRodHistory,
+  type SingleRodParams,
+} from '@/physics/induction'
+import { physicsToCanvasWithOrigin, computeScale } from '@/utils/coordinate'
+import type { CanvasSize } from '@/utils/useCanvasSize'
+
+// ─── 物理世界配置 ───────────────────────────────────────────────────────
+
+const SINGLE_ROD_WORLD = {
+  xMin: -0.5,
+  xMax: 10.0,
+  yMin: -1.5,
+  yMax: 1.5,
+} as const
+
+/** 导轨长度（物理 m） */
+const RAIL_PHYS_LENGTH = 8.0
+
+// ─── 接口定义 ───────────────────────────────────────────────────────────
+
+export interface SingleRodPhysicsParams extends SingleRodParams {
+  enableChargeSlot?: boolean
+}
+
+export interface SingleRodPhysicsResult {
+  /** 当前速度 m/s */
+  currentV: number
+  /** 当前位移 m */
+  currentX: number
+  /** 当前加速度 m/s² */
+  currentA: number
+  /** 感应电流 A */
+  currentI: number
+  /** 感应电动势 V */
+  currentEMF: number
+  /** 安培力 N（向左） */
+  currentFA: number
+  /** 累积电荷量 C */
+  currentCharge: number
+  /** 外力做功 J */
+  currentEnergyW: number
+  /** 焦耳热 J */
+  currentEnergyQ: number
+  /** 收尾速度 m/s */
+  terminalV: number
+  /** 时间常数 s */
+  tau: number
+  /** 边界判定 */
+  hasHitLimit: boolean
+
+  // ─── 画布渲染数据 ───────────────────────────────────────────────
+  /** 比例尺 px/m */
+  scale: number
+  /** 原点 X（像素） */
+  originX: number
+  /** 原点 Y（像素） */
+  originY: number
+  /** 导轨左端像素坐标 */
+  railLeftPos: { cx: number; cy: number }
+  /** 导轨右端像素坐标 */
+  railRightPos: { cx: number; cy: number }
+  /** 导体棒中心像素坐标 */
+  rodPos: { cx: number; cy: number }
+  /** 导轨间距（视觉放大 1.2×） */
+  railSpacing: number
+  /** 导轨总长度（像素） */
+  railLength: number
+
+  // ─── 图表数据 ───────────────────────────────────────────────────
+  /** 最大采样时间 */
+  T_max: number
+  /** v-t 图数据点 */
+  vtPoints: Array<{ t: number; v: number }>
+  /** I-t 图数据点 */
+  itPoints: Array<{ t: number; I: number }>
+  /** 能量图数据点 */
+  energyPoints: Array<{ t: number; W: number; Q: number; E: number }>
+  /** v-t 图 Y 轴最大值 */
+  vYMax: number
+  /** I-t 图 Y 轴最大值 */
+  iYMax: number
+  /** 能量图 Y 轴最大值 */
+  eYMax: number
+
+  // ─── 矢量箭头数据 ───────────────────────────────────────────────
+  /** 速度矢量（方向向右） */
+  velocityVector: { dx: number; dy: number; magnitude: number }
+  /** 安培力矢量（方向向左） */
+  ampereForceVector: { dx: number; dy: number; magnitude: number }
+  /** 外力矢量（方向向右） */
+  extForceVector: { dx: number; dy: number; magnitude: number }
+}
+
+/**
+ * 单杆物理 Hook
+ *
+ * @param params   单杆参数（scenario/B/L/R/m/driveValue）
+ * @param canvasSize 画布尺寸（来自 useAnimationViewport）
+ * @param time    当前动画时间 s
+ */
+export function useSingleRodPhysics(
+  params: SingleRodPhysicsParams,
+  canvasSize: CanvasSize,
+  time: number
+): SingleRodPhysicsResult {
+  const {
+    scenario = 1,
+    B = 1.0,
+    L = 0.5,
+    R = 1.0,
+    m = 0.2,
+    F_ext = 2.0,
+    enableChargeSlot = false,
+  } = params
+
+  // ─── 比例尺计算 ───────────────────────────────────────────────────
+  // splitV 预设：宽 700，高 325；场景占下半屏（约 325px 高）
+  const sceneHeight = canvasSize.height
+  const sceneWidth = canvasSize.width
+
+  const scale = useMemo(
+    () => computeScale(sceneWidth, sceneHeight, SINGLE_ROD_WORLD, 40),
+    [sceneWidth, sceneHeight]
+  )
+
+  // 原点：画布左下角（x=0 为导轨左端）
+  const originX = 1.0 * scale   // 导轨左端偏移 1m
+  const originY = sceneHeight / 2
+
+  // ─── 常量计算 ─────────────────────────────────────────────────────
+  const { v_m: terminalV, tau, a_0 } = useMemo(
+    () => computeSingleRodConstants(scenario, F_ext, B, L, R, m),
+    [scenario, F_ext, B, L, R, m]
+  )
+
+  // 最大采样时间
+  const T_max = useMemo(
+    () => Math.max(6.0, Math.min(20.0, 4.5 * tau)),
+    [tau]
+  )
+
+  // ─── 图表数据预计算 ───────────────────────────────────────────────
+  const { vtPoints, itPoints, energyPoints, vMax, IMax, energyMax } =
+    useMemo(() => {
+      const historyParams: SingleRodParams = { scenario, B, L, R, m, F_ext }
+      return generateSingleRodHistory(T_max, historyParams, 100)
+    }, [T_max, scenario, B, L, R, m, F_ext])
+
+  // ─── 瞬时状态计算 ─────────────────────────────────────────────────
+  const stateAtT = useMemo(
+    () => {
+      const historyParams: SingleRodParams = { scenario, B, L, R, m, F_ext }
+      return computeSingleRodStateAtTime(time, historyParams)
+    },
+    [time, scenario, B, L, R, m, F_ext]
+  )
+
+  // ─── 画布坐标计算 ─────────────────────────────────────────────────
+  const { railLeftPos, railRightPos, rodPos, railSpacing, railLength } =
+    useMemo(() => {
+      const toCanvas = (wx: number, wy: number) => {
+        const { x, y } = physicsToCanvasWithOrigin(wx, wy, originX, originY, scale)
+        return { cx: x, cy: y }
+      }
+
+      return {
+        railLeftPos: toCanvas(0, 0),
+        railRightPos: toCanvas(RAIL_PHYS_LENGTH, 0),
+        rodPos: toCanvas(stateAtT.x, 0),
+        // 导轨间距视觉放大 1.2×（物理计算 L 保持规范米制）
+        railSpacing: L * scale * 1.2,
+        railLength: RAIL_PHYS_LENGTH * scale,
+      }
+    }, [stateAtT.x, originX, originY, scale, L])
+
+  // ─── 矢量箭头数据 ─────────────────────────────────────────────────
+  // 使用物理量的参考标量进行归一化
+  const velocityRef = Math.max(0.5, terminalV * 1.2)
+  const forceRef = Math.max(0.5, F_ext)
+
+  const velocityVector = useMemo(() => {
+    const mag = Math.abs(stateAtT.v)
+    const normalizedMag = mag / velocityRef  // 归一化到 [0, 1]
+    return {
+      dx: stateAtT.v >= 0 ? 1 : -1,
+      dy: 0,
+      magnitude: Math.min(normalizedMag, 1) * 60,  // 最大 60px
+    }
+  }, [stateAtT.v, velocityRef])
+
+  const ampereForceVector = useMemo(() => {
+    const mag = Math.abs(stateAtT.F_A)
+    const normalizedMag = mag / forceRef
+    return {
+      dx: -1,  // 始终向左
+      dy: 0,
+      magnitude: Math.min(normalizedMag, 1) * 60,
+    }
+  }, [stateAtT.F_A, forceRef])
+
+  const extForceVector = useMemo(() => {
+    const mag = scenario === 1 ? F_ext : (stateAtT.v >= 0 ? stateAtT.F_A : -stateAtT.F_A)
+    return {
+      dx: 1,
+      dy: 0,
+      magnitude: Math.min(mag / forceRef, 1) * 60,
+    }
+  }, [scenario, F_ext, stateAtT.v, stateAtT.F_A, forceRef])
+
+  return {
+    currentV: stateAtT.v,
+    currentX: stateAtT.x,
+    currentA: stateAtT.a,
+    currentI: stateAtT.I,
+    currentEMF: stateAtT.EMF,
+    currentFA: stateAtT.F_A,
+    currentCharge: stateAtT.charge,
+    currentEnergyW: stateAtT.energyW,
+    currentEnergyQ: stateAtT.energyQ,
+    terminalV,
+    tau,
+    hasHitLimit: stateAtT.hasHitLimit,
+    scale,
+    originX,
+    originY,
+    railLeftPos,
+    railRightPos,
+    rodPos,
+    railSpacing,
+    railLength,
+    T_max,
+    vtPoints,
+    itPoints,
+    energyPoints,
+    vYMax: vMax,
+    iYMax: IMax,
+    eYMax: energyMax,
+    velocityVector,
+    ampereForceVector,
+    extForceVector,
+  }
+}

