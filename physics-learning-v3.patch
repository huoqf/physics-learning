+  impulse: '#EC4899',
+} as const
+
+// 电磁学颜色（关键：安培力/洛伦兹力 = lorentzForce 紫色）
+const _electricFieldBase = '#D97706'
+const _magneticFieldBase = '#10B981'
+
+export const EM_COLORS = {
+  electricField: _electricFieldBase,
+  electricFieldLine: withAlpha(_electricFieldBase, 0.42),
+  magneticField: _magneticFieldBase,
+  magneticFieldLine: withAlpha(_magneticFieldBase, 0.38),
+  magneticFieldDot: withAlpha(_magneticFieldBase, 0.45),
+  magneticFieldCross: withAlpha(_magneticFieldBase, 0.45),
+  electricCurrent: '#DC2626',
+  positiveCharge: '#EF4444',
+  negativeCharge: '#3B82F6',
+  lorentzForce: '#8B5CF6',       // ⚠️ 安培力 F_A 专用：洛伦兹紫
+  emf: '#D97706',
+  magnetNorth: '#DC2626',
+  magnetSouth: '#2563EB',
+} as const
+
+// Canvas/SVG 基础设施色
+export const CANVAS_COLORS = {
+  grid: '#E2E8F0',
+  axis: '#94A3B8',
+  annotation: '#475569',
+  trackHistory: '#CBD5E1',
+  reference: '#9CA3AF',
+} as const
+
+// 图表配色
+export const CHART_COLORS = {
+  primary: '#3B82F6',
+  secondary: '#8B5CF6',
+  tertiary: '#06B6D4',
+  asymptote: '#94A3B8',
