+export const CANVAS_PRESETS = {
+  /** 全幅（单场景）：700 × 650 */
+  full: { width: 700, height: 650 },
+  /** 上下分屏（上方图 / 下方场景）：700 × 325 */
+  splitV: { width: 700, height: 325 },
+  /** 左右分屏（左侧场景 / 右侧图）：350 × 650 */
+  splitH: { width: 350, height: 650 },
+  /** 正方（圆周/旋转对称场景）：650 × 650 */
+  square: { width: 650, height: 650 },
+} as const
+
+export type CanvasPresetKey = keyof typeof CANVAS_PRESETS

