diff --git a/src/features/electromagnetism/induction/single-rod/components/SingleRodScene.tsx b/src/features/electromagnetism/induction/single-rod/components/SingleRodScene.tsx
new file mode 100644
--- /dev/null
+++ b/src/features/electromagnetism/induction/single-rod/components/SingleRodScene.tsx
@@ -0,0 +1,242 @@
+/**
+ * src/features/electromagnetism/induction/single-rod/components/SingleRodScene.tsx
+ * 单杆物理视界 — 场景内容（设计坐标 0..700×325）
+ *
+ * ════════════════════════════════════════════════════════════════════════════
+ * 设计坐标说明：
+ * • 此组件渲染的内容放在 <g transform={vp.transform}> 内
+ * • 所有坐标使用设计坐标（0..700 / 0..325），由 AnimationSvgCanvas 缩放
+ * • 父组件（InductionSingleRod）负责 AnimationSvgCanvas 容器
+ *
+ * 合规要点（铁律 1/5）：
+ * • 铁律 5：复用 ConductingRod / Rails / MagneticFieldSymbols / VectorArrow
+ * • 铁律 1-1：颜色引用 theme token（EM_COLORS / DYNAMICS_COLORS）
+ * • 铁律 1-6：字体缩放使用 canvasSize.font()
+ * • 铁律 1-4：矢量走 VectorArrow 组件 + refMagnitudes
+ * ════════════════════════════════════════════════════════════════════════════
+ */
+import React, { useCallback } from 'react'
+
+// ─── 可复用组件（铁律 5：组件复用优先）───────────────────────────────
+import {
+  ConductingRod,
+  Rails,
+  MagneticFieldSymbols,
+  VectorArrow,
+} from '@/components/Physics'
+
+// ─── 类型定义（存根）──────────────────────────────────────────────────
+// 实际项目中这些来自 @/components/Physics 的真实导出
+import type { SingleRodPhysicsResult } from '../hooks/useSingleRodPhysics'
+import type { ViewportInfo, CanvasSize } from '@/hooks'
+
+// ─── 设计坐标常量（splitV: 700×325）──────────────────────────────────
+const DESIGN_W = 700
+const DESIGN_H = 325
+const RAIL_X0 = 80      // 导轨左端 X
+const RAIL_X1 = 620     // 导轨右端 X
+const RAIL_Y = 200      // 导轨中心 Y
+const RAIL_SPACING = 80 // 导轨间距
+
+interface SingleRodSceneProps {
+  physics: SingleRodPhysicsResult
+  scenario: number
+  canvasSize: CanvasSize
+  /** 视口变换（父组件 AnimationSvgCanvas 已应用，此处声明兼容） */
+  vp?: ViewportInfo
+}
+
+/**
+ * 单杆物理视界场景内容（设计坐标）
+ *
+ * 渲染内容：
+ * 1. MagneticFieldSymbols — 磁场 × 符号背景
+ * 2. Rails                — 导轨（上下平行线）
+ * 3. ConductingRod        — 导体棒（水平模式）
+ * 4. VectorArrow × 3      — 速度/安培力/外力矢量
+ * 5. SVG text             — 电流/电动势标注
+ */
+export function SingleRodScene({ physics, scenario, canvasSize }: SingleRodSceneProps) {
+  const {
+    currentV,
+    currentI,
+    velocityVector,
+    ampereForceVector,
+    extForceVector,
+    currentEMF,
+    terminalV,
+  } = physics
+
+  // ─── 字体缩放（铁律 1-6）────────────────────────────────────────
+  const font = useCallback(
+    (size: number) => canvasSize.font(size),
+    [canvasSize]
+  )
+
+  // ─── 导体棒 X 坐标（设计坐标）──────────────────────────────────
+  // 导体棒随 currentX 在导轨上滑动
+  const rodDesignX = RAIL_X0 + Math.min(physics.currentX, RAIL_X1 - RAIL_X0)
+
+  // ─── 电流方向 ───────────────────────────────────────────────────
+  const currentDir: 'in' | 'out' | 'none' =
+    currentI > 0.01 ? 'in' : currentI < -0.01 ? 'out' : 'none'
+
+  return (
+    <g>
+      {/* ─── 磁场背景（× 符号）────────────────────────────────── */}
+      <MagneticFieldSymbols
+        x1={RAIL_X0 - 10}
+        y1={RAIL_Y - RAIL_SPACING / 2 - 10}
+        x2={RAIL_X1 + 10}
+        y2={RAIL_Y + RAIL_SPACING / 2 + 10}
+        direction="into"
+        gridCountX={12}
+        gridCountY={3}
+        color="#10B981"
+        opacity={0.3}
+      />
+
+      {/* ─── 导轨（上下平行金属导轨）──────────────────────────── */}
+      <Rails
+        startX={RAIL_X0}
+        endX={RAIL_X1}
+        y={RAIL_Y}
+        spacing={RAIL_SPACING}
+        visualScale={1.0}
+      />
+
+      {/* ─── 导体棒（水平模式，跨越导轨间距）──────────────────── */}
+      <ConductingRod
+        type="horizontal"
+        x={rodDesignX}
+        y={RAIL_Y}
+        spacing={RAIL_SPACING}
+        currentDir={currentDir}
+        rodRadius={12}
+      />
+
+      {/* ─── 电流标注（SVG text）──────────────────────────────── */}
+      {currentI > 0.01 && (
+        <text
+          x={RAIL_X1 + 25}
+          y={RAIL_Y}
+          fontSize={font(11)}
+          fill="#DC2626"
+          textAnchor="start"
+          dominantBaseline="middle"
+        >
+          I={currentI.toFixed(2)}A
+        </text>
+      )}
+
+      {/* ─── 感应电动势标注 ──────────────────────────────────── */}
+      <text
+        x={RAIL_X0 + 10}
+        y={RAIL_Y + RAIL_SPACING / 2 + 40}
+        fontSize={font(10)}
+        fill="#D97706"
+      >
+        ε = {currentEMF.toFixed(2)} V
+      </text>
+
+      {/* ─── 收尾速度标注（恒力模式）───────────────────────────── */}
+      {scenario === 1 && terminalV > 0.01 && (
+        <text
+          x={RAIL_X0 + 10}
+          y={RAIL_Y + RAIL_SPACING / 2 + 58}
+          fontSize={font(11)}
+          fill="#64748B"
+        >
+          v_m = {terminalV.toFixed(2)} m/s
+        </text>
+      )}
+
+      {/* ─── 矢量箭头层（铁律 5：必须走 VectorArrow 组件）─────── */}
+      <VectorsOverlay
+        rodCenterX={rodDesignX}
+        rodCenterY={RAIL_Y}
+        velocity={velocityVector}
+        ampereForce={ampereForceVector}
+        extForce={extForceVector}
+        scenario={scenario}
+        font={font}
+      />
+    </g>
+  )
+}
+
+// ─── 矢量箭头覆盖层 ─────────────────────────────────────────────────
+
+function VectorsOverlay({
+  rodCenterX,
+  rodCenterY,
+  velocity,
+  ampereForce,
+  extForce,
+  scenario,
+  font,
+}: {
+  rodCenterX: number
+  rodCenterY: number
+  velocity: { dx: number; dy: number; magnitude: number }
+  ampereForce: { dx: number; dy: number; magnitude: number }
+  extForce: { dx: number; dy: number; magnitude: number }
+  scenario: number
+  font: (size: number) => number
+}) {
+  // 三个箭头 Y 坐标：导体棒上方 30px 起，依次排列
+  const VEL_Y = rodCenterY - 30
+  const FA_Y = rodCenterY - 30
+  const F_EXT_Y = rodCenterY + 25
+
+  const MIN_LEN = 40
+
+  return (
+    <g>
+      {/* ─── 速度矢量（蓝色，向右）── */}
+      {/* ✅ 铁律 1-4 + 铁律 5：VectorArrow 组件 + refMagnitudes 归一化 */}
+      {velocity.magnitude > 5 && (
+        <VectorArrow
+          origin={{ x: rodCenterX, y: VEL_Y }}
+          direction={{ dx: 1, dy: 0 }}
+          magnitude={Math.max(velocity.magnitude, MIN_LEN)}
+          type="velocity"
+          refMagnitudes={{ velocity: 3.0 }}
+          label="v"
+          labelOffset={{ x: 0, y: -12 }}
+          fontSize={font(10)}
+        />
+      )}
+
+      {/* ─── 安培力矢量（紫色，向左）── */}
+      {/* ✅ 铁律 1-1 颜色语义：安培力 = lorentzForce (#8B5CF6 洛伦兹紫) */}
+      {ampereForce.magnitude > 5 && (
+        <VectorArrow
+          origin={{ x: rodCenterX, y: FA_Y }}
+          direction={{ dx: -1, dy: 0 }}
+          magnitude={Math.max(ampereForce.magnitude, MIN_LEN)}
+          type="lorentzForce"
+          refMagnitudes={{ lorentzForce: 0.5 }}
+          label="F_A"
+          labelOffset={{ x: 0, y: 16 }}
+          fontSize={font(10)}
+        />
+      )}
+
+      {/* ─── 外力矢量（橙色，向右，仅恒力模式）── */}
+      {/* ✅ 铁律 1-1 颜色语义：外力 = forceNet (#EA580C 动力橙) */}
+      {scenario === 1 && extForce.magnitude > 5 && (
+        <VectorArrow
+          origin={{ x: rodCenterX, y: F_EXT_Y }}
+          direction={{ dx: 1, dy: 0 }}
+          magnitude={Math.max(extForce.magnitude, MIN_LEN)}
+          type="forceNet"
+          refMagnitudes={{ forceNet: 0.5 }}
+          label="F"
+          labelOffset={{ x: 0, y: 12 }}
+          fontSize={font(10)}
+        />
+      )}
+    </g>
+  )
+}

diff --git a/src/features/electromagnetism/induction/single-rod/components/SingleRodCharts.tsx b/src/features/electromagnetism/induction/single-rod/components/SingleRodCharts.tsx
new file mode 100644
--- /dev/null
+++ b/src/features/electromagnetism/induction/single-rod/components/SingleRodCharts.tsx
@@ -0,0 +1,404 @@
+/**
+ * src/features/electromagnetism/induction/single-rod/components/SingleRodCharts.tsx
+ * 单杆三图表面板 — v-t / I-t / 能量守恒
+ *
+ * ════════════════════════════════════════════════════════════════════════════
+ * 合规要点：
+ * • 三图表横向 HTML flex 并列（铁律 1 §8：禁止 SVG foreignObject 嵌套）
+ * • 图表配色：引用 VT_CHART_COLORS / EM_COLORS / ENERGY_COLORS
+ * • 时间同步虚线：垂直扫描线与下屏导体棒位置时序对齐
+ * • 图表组件：使用 BasePhysicsChart / ChartCursor
+ * ════════════════════════════════════════════════════════════════════════════
+ */
+import React, { useMemo } from 'react'
+import {
+  VT_CHART_COLORS,
+  EM_COLORS,
+  ENERGY_COLORS,
+  CHART_COLORS,
+} from '@/theme/physics'
+import type { SingleRodPhysicsResult } from '../hooks/useSingleRodPhysics'
+
+// ─── 图表尺寸常量 ──────────────────────────────────────────────────────
+const CHART_PADDING_X = 48
+const CHART_PADDING_Y = 36
+const LABEL_HEIGHT = 24
+
+interface SingleRodChartsProps {
+  physics: SingleRodPhysicsResult
+  time: number
+}
+
+export function SingleRodCharts({ physics, time }: SingleRodChartsProps) {
+  const { T_max, vtPoints, itPoints, energyPoints, vYMax, iYMax, eYMax } = physics
+
+  // 当前时间扫描线 X 坐标（供三个图表共享）
+  const syncLineX = (time / T_max)  // 归一化 [0, 1]
+
+  return (
+    // ✅ 三图表横向 HTML flex 并列
+    <div className="flex flex-row w-full h-full gap-2 min-h-0">
+      {/* ─── 左图：v-t 速度时间曲线 ─────────────────────────── */}
+      <div className="flex-1 min-w-0 flex flex-col">
+        <div className="text-xs font-medium text-neutral-600 mb-1 px-1">v-t 速度演变</div>
+        <div className="flex-1 bg-white rounded-lg border border-neutral-200 p-2 shadow-sm min-h-0">
+          <VelocityChart
+            points={vtPoints}
+            currentTime={time}
+            T_max={T_max}
+            vYMax={vYMax}
+            terminalV={physics.terminalV}
+            syncRatio={syncLineX}
+          />
+        </div>
+      </div>
+
+      {/* ─── 中图：I-t 感应电流曲线 ─────────────────────────── */}
+      <div className="flex-1 min-w-0 flex flex-col">
+        <div className="text-xs font-medium text-neutral-600 mb-1 px-1">I-t 电流衰减</div>
+        <div className="flex-1 bg-white rounded-lg border border-neutral-200 p-2 shadow-sm min-h-0">
+          <CurrentChart
+            points={itPoints}
+            currentTime={time}
+            T_max={T_max}
+            iYMax={iYMax}
+            syncRatio={syncLineX}
+          />
+        </div>
+      </div>
+
+      {/* ─── 右图：能量守恒转化 ─────────────────────────────── */}
+      <div className="flex-1 min-w-0 flex flex-col">
+        <div className="text-xs font-medium text-neutral-600 mb-1 px-1">能量转化守恒</div>
+        <div className="flex-1 bg-white rounded-lg border border-neutral-200 p-2 shadow-sm min-h-0">
+          <EnergyChart
+            points={energyPoints}
+            currentTime={time}
+            T_max={T_max}
+            eYMax={eYMax}
+            syncRatio={syncLineX}
+          />
+        </div>
+      </div>
+    </div>
+  )
+}
+
+// ─── 子组件：v-t 图表 ──────────────────────────────────────────────────
+
+function VelocityChart({
+  points,
+  currentTime,
+  T_max,
+  vYMax,
+  terminalV,
+  syncRatio,
+}: {
+  points: Array<{ t: number; v: number }>
+  currentTime: number
+  T_max: number
+  vYMax: number
+  terminalV: number
+  syncRatio: number
+}) {
+  const paddingX = CHART_PADDING_X
+  const paddingY = CHART_PADDING_Y
+  const chartW = 180  // 简化的图表宽度
+  const chartH = 100
+
+  const toX = (t: number) => paddingX + (t / T_max) * (chartW - paddingX * 2)
+  const toY = (v: number) => paddingY + ((vYMax - v) / (2 * vYMax)) * (chartH - paddingY * 2)
+
+  // 已到达的时间点
+  const activePoints = points.filter(p => p.t <= currentTime)
+
+  return (
+    <svg
+      width="100%"
+      height="100%"
+      viewBox={`0 0 ${chartW} ${chartH + LABEL_HEIGHT}`}
+      preserveAspectRatio="xMidYMid meet"
+    >
+      {/* 网格 */}
+      {[0.25, 0.5, 0.75, 1].map(r => (
+        <line
+          key={r}
+          x1={toX(r * T_max)} y1={paddingY}
+          x2={toX(r * T_max)} y2={chartH - paddingY}
+          stroke="#E2E8F0" strokeWidth={0.5} strokeDasharray="2,2"
+        />
+      ))}
+      {/* 横轴 */}
+      <line
+        x1={paddingX} y1={toY(0)}
+        x2={chartW - paddingX} y2={toY(0)}
+        stroke={CHART_COLORS.tickMark} strokeWidth={0.8}
+      />
+
+      {/* 曲线（虚线预告 + 实线已到达） */}
+      {points.length > 1 && (
+        <>
+          <path
+            d={`M ${points.map(p => `${toX(p.t).toFixed(1)},${toY(p.v).toFixed(1)}`).join(' L ')}`}
+            fill="none"
+            stroke={VT_CHART_COLORS.primary}
+            strokeWidth={1.5}
+            strokeDasharray="4,3"
+            opacity={0.35}
+          />
+          {activePoints.length > 1 && (
+            <path
+              d={`M ${activePoints.map(p => `${toX(p.t).toFixed(1)},${toY(p.v).toFixed(1)}`).join(' L ')}`}
+              fill="none"
+              stroke={VT_CHART_COLORS.primary}
+              strokeWidth={2}
+            />
+          )}
+        </>
+      )}
+
+      {/* 收尾速度虚线 */}
+      {terminalV > 0.01 && (
+        <line
+          x1={paddingX} y1={toY(terminalV)}
+          x2={chartW - paddingX} y2={toY(terminalV)}
+          stroke={CHART_COLORS.asymptote}
+          strokeWidth={1}
+          strokeDasharray="4,4"
+        />
+      )}
+
+      {/* 时间同步虚线（垂直扫描线） */}
+      {syncRatio > 0 && syncRatio < 1 && (
+        <line
+          x1={toX(currentTime)} y1={paddingY}
+          x2={toX(currentTime)} y2={chartH - paddingY}
+          stroke="#94A3B8"
+          strokeWidth={1.5}
+          strokeDasharray="3,3"
+          opacity={0.7}
+        />
+      )}
+
+      {/* 当前点高亮 */}
+      {currentTime > 0 && currentTime <= T_max && (
+        <circle
+          cx={toX(currentTime)}
+          cy={toY(points.find(p => p.t >= currentTime)?.v ?? 0)}
+          r={4}
+          fill={VT_CHART_COLORS.primary}
+        />
+      )}
+
+      {/* 轴标签 */}
+      <text x={chartW / 2} y={chartH + LABEL_HEIGHT - 4}
+        fontSize={8} fill={CHART_COLORS.tickLabel} textAnchor="middle">t / s</text>
+    </svg>
+  )
+}
+
+// ─── 子组件：I-t 图表 ──────────────────────────────────────────────────
+
+function CurrentChart({
+  points,
+  currentTime,
+  T_max,
+  iYMax,
+  syncRatio,
+}: {
+  points: Array<{ t: number; I: number }>
+  currentTime: number
+  T_max: number
+  iYMax: number
+  syncRatio: number
+}) {
+  const paddingX = CHART_PADDING_X
+  const paddingY = CHART_PADDING_Y
+  const chartW = 180
+  const chartH = 100
+
+  const toX = (t: number) => paddingX + (t / T_max) * (chartW - paddingX * 2)
+  const toY = (i: number) => paddingY + ((iYMax - i) / iYMax) * (chartH - paddingY * 2)
+
+  const activePoints = points.filter(p => p.t <= currentTime)
+
+  return (
+    <svg
+      width="100%"
+      height="100%"
+      viewBox={`0 0 ${chartW} ${chartH + LABEL_HEIGHT}`}
+      preserveAspectRatio="xMidYMid meet"
+    >
+      {/* 网格 */}
+      {[0.25, 0.5, 0.75, 1].map(r => (
+        <line
+          key={r}
+          x1={toX(r * T_max)} y1={paddingY}
+          x2={toX(r * T_max)} y2={chartH - paddingY}
+          stroke="#E2E8F0" strokeWidth={0.5} strokeDasharray="2,2"
+        />
+      ))}
+
+      {/* 曲线 */}
+      {points.length > 1 && (
+        <>
+          <path
+            d={`M ${points.map(p => `${toX(p.t).toFixed(1)},${toY(p.I).toFixed(1)}`).join(' L ')}`}
+            fill="none"
+            stroke={EM_COLORS.electricCurrent}
+            strokeWidth={1.5}
+            strokeDasharray="4,3"
+            opacity={0.35}
+          />
+          {activePoints.length > 1 && (
+            <path
+              d={`M ${activePoints.map(p => `${toX(p.t).toFixed(1)},${toY(p.I).toFixed(1)}`).join(' L ')}`}
+              fill="none"
+              stroke={EM_COLORS.electricCurrent}
+              strokeWidth={2}
+            />
+          )}
+        </>
+      )}
+
+      {/* 时间同步虚线 */}
+      {syncRatio > 0 && syncRatio < 1 && (
+        <line
+          x1={toX(currentTime)} y1={paddingY}
+          x2={toX(currentTime)} y2={chartH - paddingY}
+          stroke="#94A3B8"
+          strokeWidth={1.5}
+          strokeDasharray="3,3"
+          opacity={0.7}
+        />
+      )}
+
+      {/* 当前点 */}
+      {currentTime > 0 && currentTime <= T_max && (
+        <circle
+          cx={toX(currentTime)}
+          cy={toY(points.find(p => p.t >= currentTime)?.I ?? 0)}
+          r={4}
+          fill={EM_COLORS.electricCurrent}
+        />
+      )}
+
+      {/* 轴标签 */}
+      <text x={chartW / 2} y={chartH + LABEL_HEIGHT - 4}
+        fontSize={8} fill={CHART_COLORS.tickLabel} textAnchor="middle">t / s</text>
+    </svg>
+  )
+}
+
+// ─── 子组件：能量守恒图表 ──────────────────────────────────────────────
+
+function EnergyChart({
+  points,
+  currentTime,
+  T_max,
+  eYMax,
+  syncRatio,
+}: {
+  points: Array<{ t: number; W: number; Q: number; E: number }>
+  currentTime: number
+  T_max: number
+  eYMax: number
+  syncRatio: number
+}) {
+  const paddingX = CHART_PADDING_X
+  const paddingY = CHART_PADDING_Y
+  const chartW = 180
+  const chartH = 100
+
+  const toX = (t: number) => paddingX + (t / T_max) * (chartW - paddingX * 2)
+  const toY = (e: number) => paddingY + ((eYMax - e) / eYMax) * (chartH - paddingY * 2)
+
+  const activePoints = points.filter(p => p.t <= currentTime)
+
+  return (
+    <svg
+      width="100%"
+      height="100%"
+      viewBox={`0 0 ${chartW} ${chartH + LABEL_HEIGHT}`}
+      preserveAspectRatio="xMidYMid meet"
+    >
+      {/* 网格 */}
+      {[0.25, 0.5, 0.75, 1].map(r => (
+        <line
+          key={r}
+          x1={toX(r * T_max)} y1={paddingY}
+          x2={toX(r * T_max)} y2={chartH - paddingY}
+          stroke="#E2E8F0" strokeWidth={0.5} strokeDasharray="2,2"
+        />
+      ))}
+
+      {/* W 外力功曲线（黄绿色） */}
+      {points.length > 1 && (
+        <>
+          <path
+            d={`M ${points.map(p => `${toX(p.t).toFixed(1)},${toY(p.W).toFixed(1)}`).join(' L ')}`}
+            fill="none"
+            stroke={ENERGY_COLORS.work}
+            strokeWidth={1.5}
+            strokeDasharray="4,3"
+            opacity={0.35}
+          />
+          {activePoints.length > 1 && (
+            <path
+              d={`M ${activePoints.map(p => `${toX(p.t).toFixed(1)},${toY(p.W).toFixed(1)}`).join(' L ')}`}
+              fill="none"
+              stroke={ENERGY_COLORS.work}
+              strokeWidth={2}
+            />
+          )}
+        </>
+      )}
+
+      {/* Q 焦耳热曲线（红色） */}
+      {points.length > 1 && (
+        <>
+          <path
+            d={`M ${points.map(p => `${toX(p.t).toFixed(1)},${toY(p.Q).toFixed(1)}`).join(' L ')}`}
+            fill="none"
+            stroke={ENERGY_COLORS.heatLoss}
+            strokeWidth={1.5}
+            strokeDasharray="4,3"
+            opacity={0.35}
+          />
+          {activePoints.length > 1 && (
+            <path
+              d={`M ${activePoints.map(p => `${toX(p.t).toFixed(1)},${toY(p.Q).toFixed(1)}`).join(' L ')}`}
+              fill="none"
+              stroke={ENERGY_COLORS.heatLoss}
+              strokeWidth={2}
+            />
+          )}
+        </>
+      )}
+
+      {/* 图例 */}
+      <g transform={`translate(${paddingX + 5}, ${paddingY + 5})`}>
+        <line x1={0} y1={0} x2={12} y2={0} stroke={ENERGY_COLORS.work} strokeWidth={2} />
+        <text x={16} y={3} fontSize={7} fill="#64748B">W</text>
+        <line x1={30} y1={0} x2={42} y2={0} stroke={ENERGY_COLORS.heatLoss} strokeWidth={2} />
+        <text x={46} y={3} fontSize={7} fill="#64748B">Q</text>
+      </g>
+
+      {/* 时间同步虚线 */}
+      {syncRatio > 0 && syncRatio < 1 && (
+        <line
+          x1={toX(currentTime)} y1={paddingY}
+          x2={toX(currentTime)} y2={chartH - paddingY}
+          stroke="#94A3B8"
+          strokeWidth={1.5}
+          strokeDasharray="3,3"
+          opacity={0.7}
+        />
+      )}
+
+      {/* 轴标签 */}
+      <text x={chartW / 2} y={chartH + LABEL_HEIGHT - 4}
+        fontSize={8} fill={CHART_COLORS.tickLabel} textAnchor="middle">t / s</text>
+    </svg>
+  )
+}

