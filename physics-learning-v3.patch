+/**
+ * src/features/electromagnetism/induction/InductionSingleRod.tsx
+ * 电磁感应单杆模型 — 主屏入口（薄壳）
+ *
+ * ════════════════════════════════════════════════════════════════════════════
+ * 合规要点（铁律 1/3/6）：
+ *
+ * • 页面薄壳化：主屏仅负责布局和数据注入，不放业务逻辑
+ * • 视图端口：useAnimationViewport({ preset: CANVAS_PRESETS.splitV }) + AnimationSvgCanvas
+ * • splitV 上下等分：上图表 / 下场景
+ * • 三屏划分：左参数 / 中画布 / 右公式（由 AnimationPage 统一处理）
+ *
+ * 布局模型：
+ * ┌────────────────────────────────────────────────────────┐
+ * │ 上半屏 (h-1/2)：三图表横向并列 HTML flex              │
+ * │ <SingleRodCharts physics={physics} time={time} />     │
+ * ├────────────────────────────────────────────────────────┤
+ * │ 下半屏 (flex-1)：AnimationSvgCanvas + 物理视界        │
+ * │ <AnimationSvgCanvas containerRef={containerRef}       │
+ * │         transform={vp.transform}>                      │
+ * │   <SingleRodScene physics={physics} scenario={...} /> │
+ * │ </AnimationSvgCanvas>                                 │
+ * └────────────────────────────────────────────────────────┘
+ * ════════════════════════════════════════════════════════════════════════════
+ */
+import React, { useEffect, useRef } from 'react'
+import { useAnimationStore } from '@/stores'
+import { useShallow } from 'zustand/react/shallow'
+import { useAnimationViewport } from '@/hooks'
+import { CANVAS_PRESETS } from '@/theme/spacing'
+
+import { AnimationSvgCanvas } from '@/components/Layout'
+import { SingleRodScene } from './single-rod/components/SingleRodScene'
+import { SingleRodCharts } from './single-rod/components/SingleRodCharts'
+import { useSingleRodPhysics } from './single-rod/hooks/useSingleRodPhysics'
+
+export default function InductionSingleRod() {
+  // ─── 从动画 Store 读取状态 ────────────────────────────────────────
+  const { params, time, isPlaying, setIsPlaying } = useAnimationStore(
+    useShallow(s => ({
+      params: s.params,
+      time: s.time,
+      isPlaying: s.isPlaying,
+      setIsPlaying: s.setIsPlaying,
+    }))
+  )
+
+  const {
+    scenario = 1,
+    B = 1.0,
+    L = 0.5,
+    R = 1.0,
+    m = 0.2,
+    driveValue = 2.0,
+  } = params as Record<string, unknown>
+
+  // 启动机制映射：scenario=0 → driveValue=v₀(m/s)，scenario=1 → driveValue=F(N)
+  const F_ext = driveValue as number
+
+  // ─── Viewport（铁律 1-7 新标准路径）───────────────────────────────
+  // splitV: { width: 700, height: 325 } — 上下等分
+  const { containerRef, canvasSize, vp } = useAnimationViewport({
+    preset: CANVAS_PRESETS.splitV,
+  })
+
+  // ─── 物理层 Hook ──────────────────────────────────────────────────
+  const physics = useSingleRodPhysics(
+    { scenario: scenario as number, B: B as number, L: L as number, R: R as number, m: m as number, F_ext },
+    canvasSize,
+    time
+  )
+
+  // ─── 边界处理 ─────────────────────────────────────────────────────
+  const prevHitLimit = useRef(false)
+  useEffect(() => {
+    if (physics.hasHitLimit && !prevHitLimit.current) {
+      setIsPlaying(false)
+    }
+    prevHitLimit.current = physics.hasHitLimit
+  }, [physics.hasHitLimit, setIsPlaying])
+
+  // ─── 主屏布局（splitV 上下等分）───────────────────────────────────
+  return (
+    <div className="relative w-full h-full flex flex-col gap-2 p-1">
+      {/* ─── 上半屏：三图表横向并列（HTML flex） ─────────────── */}
+      {/* ✅ 铁律 1-8：图表在 HTML 层横向并列，禁止 SVG foreignObject */}
+      <div className="w-full" style={{ height: '50%', minHeight: 0 }}>
+        <SingleRodCharts physics={physics} time={time} />
+      </div>
+
+      {/* ─── 下半屏：物理视界仿真 ─────────────────────────────── */}
+      {/* ✅ 铁律 1-7：AnimationSvgCanvas 标准容器，无 viewBox */}
+      <div className="w-full flex-1 min-h-0">
+        <AnimationSvgCanvas
+          containerRef={containerRef}
+          transform={vp.transform}
+          className="bg-neutral-50 rounded-xl overflow-hidden"
+        >
+          {/* 场景内容使用设计坐标（0..700 / 0..325），由 vp.transform 缩放 */}
+          <SingleRodScene
+            physics={physics}
+            scenario={scenario as number}
+            canvasSize={canvasSize}
+          />
+        </AnimationSvgCanvas>
+      </div>
+    </div>
+  )
+}

