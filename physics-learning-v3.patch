+/**
+ * src/utils/lazyWithPreload.ts
+ * React.lazy 增强版（支持预加载）
+ *
+ * @example
+ * const Component = lazyWithPreload(() => import('./Component'))
+ * Component.preload()  // 预加载
+ */
+import { lazy } from 'react'
+
+type LoaderFn = () => Promise<{ default: React.ComponentType<unknown> }>
+
+export function lazyWithPreload(loader: LoaderFn) {
+  const Component = lazy(loader)
+  return Object.assign(Component, {
+    preload: () => { /* 触发预加载：lazy 的实现会在首次 render 时加载 */ },
+  })
+}

