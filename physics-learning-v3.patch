@@ -0,0 +1,294 @@
+/**
+ * src/features/mechanics/circular/rotating-disk/hooks/useRotatingDiskPhysics.ts
+ * 圆盘与圆锥摆物理 Hook
+ *
+ * ════════════════════════════════════════════════════════════════════════════
+ * 职责：
+ * • 封装纯函数物理计算
+ * • 生成图表采样数据
+ * • 计算画布渲染所需的像素坐标
+ * • 提供矢量箭头归一化数据
+ *
+ * 设计原则（铁律 2）：
+ * • 纯函数封装，无副作用
+ * • useMemo 缓存图表数据
+ * • 坐标转换通过物理比例尺
+ * ════════════════════════════════════════════════════════════════════════════
+ */
+import { useMemo } from 'react'
+import {
+  computeRotatingDiskConstants,
+  computeRotatingDiskStateAtTime,
+  generateRotatingDiskHistory,
+  type RotatingDiskParams,
+  type RotatingDiskModel,
+} from '@/physics/circular'
+import type { CanvasSize } from '@/utils/useCanvasSize'
+
+// ─── 接口定义 ────────────────────────────────────────────────────────
+
+export interface RotatingDiskPhysicsParams extends RotatingDiskParams {
+  /** 额外：视角缩放（用于 3D 透视投影） */
+  perspectiveScale?: number
+  /** 额外：摆线长度（圆锥摆） */
+  pendulumLength?: number
+}
+
+export interface RotatingDiskPhysicsResult {
+  // ─── 当前状态 ───────────────────────────────────────
+  /** 当前角速度 rad/s */
+  currentOmega: number
+  /** 向心力 N */
+  centripetalForce: number
+  /** 周期 s */
+  period: number
+  /** 线速度 m/s */
+  linearVelocity: number
+
+  // ─── 圆锥摆专有 ─────────────────────────────────────
+  /** 摆角 rad */
+  theta: number
+  /** 摆角 ° */
+  thetaDeg: number
+  /** 旋转半径 m */
+  rotationRadius: number
+  /** 绳拉力 N */
+  tension: number
+
+  // ─── 圆盘专有 ───────────────────────────────────────
+  /** 所需静摩擦力 N */
+  requiredFriction: number
+  /** 最大静摩擦力 N */
+  maxFriction: number
+  /** 摩擦力占比 */
+  frictionRatio: number
+  /** 安全因子 [0, 1] */
+  safetyFactor: number
+  /** 是否达到临界 */
+  isCritical: boolean
+  /** 是否已离心 */
+  isFlyOff: boolean
+
+  // ─── 画布渲染数据 ───────────────────────────────────
+  /** 物理比例尺 px/m */
+  scale: number
+  /** 中心 X（设计坐标） */
+  centerX: number
+  /** 中心 Y（设计坐标） */
+  centerY: number
+  /** 顶端悬点 Y（设计坐标，圆锥摆） */
+  topY: number
+  /** 质点位置 X */
+  particleX: number
+  /** 质点位置 Y */
+  particleY: number
+  /** 临界角速度 rad/s（圆盘模型） */
+  omegaCrit: number
+
+  // ─── 图表数据 ───────────────────────────────────────
+  /** 最大采样角速度 */
+  omegaMax: number
+  /** 向心力-角速度曲线点 */
+  forcePoints: Array<{ omega: number; force: number }>
+  /** 摆角-角速度曲线点（圆锥摆） */
+  anglePoints: Array<{ omega: number; angle: number }>
+  /** 摩擦力-角速度曲线点（圆盘） */
+  frictionPoints: Array<{ omega: number; friction: number; maxFriction: number }>
+
+  // ─── 矢量箭头数据 ───────────────────────────────────
+  /** 重力矢量（向下） */
+  gravityVector: { dx: number; dy: number; magnitude: number; color: string }
+  /** 拉力矢量（沿绳向上） */
+  tensionVector: { dx: number; dy: number; magnitude: number; color: string }
+  /** 向心力矢量（指向圆心） */
+  centripetalVector: { dx: number; dy: number; magnitude: number; color: string }
+  /** 摩擦力矢量（指向圆心） */
+  frictionVector: { dx: number; dy: number; magnitude: number; color: string }
+  /** 速度矢量（切线方向） */
+  velocityVector: { dx: number; dy: number; magnitude: number; color: string }
+}
+
+// ─── 设计坐标常量（splitH: 350×650）────────────────────────────────
+
+const DESIGN_W = 350
+const DESIGN_H = 650
+
+/** 圆盘半径设计像素 */
+const DISK_RADIUS_PX = 120
+/** 摆长设计像素（圆锥摆） */
+const PENDULUM_LENGTH_PX = 250
+
+/**
+ * 圆盘/圆锥摆物理 Hook
+ *
+ * @param params   物理参数（model/omega/L/mu/g/m）
+ * @param canvasSize 画布尺寸（来自 useAnimationViewport）
+ * @param time    当前动画时间 s
+ */
+export function useRotatingDiskPhysics(
+  params: RotatingDiskPhysicsParams,
+  canvasSize: CanvasSize,
+  time: number
+): RotatingDiskPhysicsResult {
+  const {
+    model = 'cone-pendulum' as RotatingDiskModel,
+    omega = 0,
+    L = 0.5,
+    mu = 0.5,
+    g = 9.8,
+    m = 1.0,
+  } = params
+
+  // ─── 比例尺计算 ──────────────────────────────────────────────────
+  // 基于容器宽度计算设计坐标→像素的缩放
+  const scale = useMemo(
+    () => canvasSize.width / DESIGN_W,
+    [canvasSize.width]
+  )
+
+  // 圆锥摆的中心点（画布中下区域）
+  const centerX = DESIGN_W / 2
+  const centerY = DESIGN_H * 0.55
+
+  // ─── 常量计算 ──────────────────────────────────────────────────
+  const { omegaCrit } = useMemo(
+    () => computeRotatingDiskConstants(params),
+    [params.model, params.omega, params.L, params.mu, params.g]
+  )
+
+  // ─── 图表数据预计算 ─────────────────────────────────────────────
+  // 最大角速度设为 3 倍当前值或临界值（取较大）
+  const omegaMax = useMemo(
+    () => Math.max(omega * 2, omegaCrit * 1.5, 5),
+    [omega, omegaCrit]
+  )
+
+  const { forcePoints, anglePoints, frictionPoints } = useMemo(() => {
+    return generateRotatingDiskHistory(omegaMax, params, 80)
+  }, [omegaMax, params.model, params.omega, params.L, params.mu, params.g, params.m])
+
+  // ─── 瞬时状态计算 ───────────────────────────────────────────────
+  const stateAtT = useMemo(
+    () => computeRotatingDiskStateAtTime(time, params),
+    [time, params.model, params.omega, params.L, params.mu, params.g, params.m]
+  )
+
+  // ─── 画布坐标计算 ───────────────────────────────────────────────
+  const { particleX, particleY, topY } = useMemo(() => {
+    if (model === 'cone-pendulum') {
+      // 圆锥摆：质点位置由摆角决定
+      const theta = stateAtT.theta
+      const r = stateAtT.rotationRadius
+
+      // 顶端悬点（中心正上方）
+      const topFixedY = centerY - PENDULUM_LENGTH_PX
+
+      // 质点在水平方向的偏移（旋转半径映射到像素）
+      const radiusPx = r * scale * 10  // 1m → 10px 缩放
+      const particleX_ = centerX + radiusPx * Math.cos(time * 0.5)  // 随时间旋转
+
+      // 质点在竖直方向（顶端 + 摆长投影）
+      const verticalOffset = PENDULUM_LENGTH_PX * Math.cos(theta)
+      const particleY_ = topFixedY + verticalOffset
+
+      return { particleX: particleX_, particleY: particleY_, topY: topFixedY }
+    } else {
+      // 圆盘：质点随圆盘旋转（水平面内）
+      const r = params.radius ?? L
+      const radiusPx = Math.min(r * scale * 5, DISK_RADIUS_PX)
+      const particleX_ = centerX + radiusPx * Math.cos(omega * time)
+      const particleY_ = centerY
+      return { particleX: particleX_, particleY: particleY_, topY: centerY }
+    }
+  }, [model, stateAtT, params, scale, time, omega])
+
+  // ─── 矢量箭头数据 ───────────────────────────────────────────────
+  // 归一化参考标量
+  const forceRef = Math.max(1, m * g)  // 参考力：mg
+  const velocityRef = Math.max(1, omega * L * 2)  // 参考速度：2m/s
+
+  // 重力矢量（向下，始终存在）
+  const gravityVector = useMemo(() => {
+    const mag = Math.min(1, (m * g) / forceRef) * 60
+    return { dx: 0, dy: 1, magnitude: mag, color: '#166534' }  // 深重力绿
+  }, [m, g, forceRef])
+
+  // 拉力矢量（沿绳方向，向上）
+  const tensionVector = useMemo(() => {
+    if (model === 'cone-pendulum' && stateAtT.tension > 0) {
+      const mag = Math.min(1, stateAtT.tension / forceRef) * 60
+      const dx = (particleX - centerX) / Math.max(1, Math.abs(particleX - centerX))
+      const dy = -1
+      return { dx, dy, magnitude: mag, color: '#EA580C' }  // 动力橙
+    }
+    return { dx: 0, dy: -1, magnitude: 0, color: '#EA580C' }
+  }, [model, stateAtT, forceRef, particleX, centerX])
+
+  // 向心力矢量（水平指向圆心）
+  const centripetalVector = useMemo(() => {
+    const mag = Math.min(1, stateAtT.centripetalForce / forceRef) * 60
+    const dx = -Math.sign(particleX - centerX)
+    return { dx, dy: 0, magnitude: mag, color: '#EA580C' }  // 动力橙
+  }, [stateAtT, forceRef, particleX, centerX])
+
+  // 摩擦力矢量（指向圆心，仅圆盘模型）
+  const frictionVector = useMemo(() => {
+    if (model === 'rotating-disk' && stateAtT.requiredFriction > 0) {
+      const mag = Math.min(1, stateAtT.requiredFriction / forceRef) * 60
+      const dx = -Math.sign(particleX - centerX)
+      return { dx, dy: 0, magnitude: mag, color: '#D97706' }  // 琥珀橙
+    }
+    return { dx: 0, dy: 0, magnitude: 0, color: '#D97706' }
+  }, [model, stateAtT, forceRef, particleX, centerX])
+
+  // 速度矢量（切线方向，垂直于半径）
+  const velocityVector = useMemo(() => {
+    if (omega > 0.01) {
+      const mag = Math.min(1, stateAtT.linearVelocity / velocityRef) * 60
+      // 切线方向：垂直于半径方向（逆时针为正）
+      const tangentDx = -(particleY - centerY)
+      const tangentDy = particleX - centerX
+      const norm = Math.sqrt(tangentDx * tangentDx + tangentDy * tangentDy)
+      return {
+        dx: norm > 0 ? tangentDx / norm : 1,
+        dy: norm > 0 ? tangentDy / norm : 0,
+        magnitude: mag,
+        color: '#2563EB',  // 经典蓝
+      }
+    }
+    return { dx: 1, dy: 0, magnitude: 0, color: '#2563EB' }
+  }, [omega, stateAtT, velocityRef, particleX, particleY, centerX, centerY])
+
+  return {
+    currentOmega: stateAtT.omega,
+    centripetalForce: stateAtT.centripetalForce,
+    period: stateAtT.period,
+    linearVelocity: stateAtT.linearVelocity,
+    theta: stateAtT.theta,
+    thetaDeg: stateAtT.thetaDeg,
+    rotationRadius: stateAtT.rotationRadius,
+    tension: stateAtT.tension,
+    requiredFriction: stateAtT.requiredFriction,
+    maxFriction: stateAtT.maxFriction,
+    frictionRatio: stateAtT.frictionRatio,
+    safetyFactor: stateAtT.safetyFactor,
+    isCritical: stateAtT.isCritical,
+    isFlyOff: stateAtT.isFlyOff,
+    omegaCrit,
+    scale,
+    centerX,
+    centerY,
+    topY,
+    particleX,
+    particleY,
+    omegaMax,
+    forcePoints,
+    anglePoints,
+    frictionPoints,
+    gravityVector,
+    tensionVector,
+    centripetalVector,
+    frictionVector,
+    velocityVector,
+  }
+}

