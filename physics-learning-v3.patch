+/**
+ * src/utils/useCanvasSize.ts
+ * 标准画布尺寸 Hook（返回 [ref, CanvasSize] 元组）
+ *
+ * 与项目标准完全一致，用于 useAnimationViewport 内部组合
+ */
+import { useState, useRef, useEffect, useCallback } from 'react'
+
+export interface CanvasSize {
+  /** 容器实际宽度 px */
+  width: number
+  /** 容器实际高度 px */
+  height: number
+  /**
+   * 字体大小（带 clamp 7-16）
+   * 用于 SVG text / VectorArrow label
+   * @param base 设计字体大小
+   */
+  font: (base: number) => number
+  /**
+   * 像素单位换算（设计坐标 px → 实际 px）
+   * @param design 设计坐标像素
+   */
+  px: (design: number) => number
+  /** 当前缩放比（实际 / 设计） */
+  scale: number
+}
+
+/** canvasSize.font 的 clamp 范围 */
+const FONT_MIN = 7
+const FONT_MAX = 16
+
+/**
+ * 监听容器尺寸变化，返回 [ref, canvasSize] 元组
+ *
+ * @param designSize 设计尺寸（通常来自 CANVAS_PRESETS）
+ * @param options.presetCompensation 代偿系数（旧 preset 迁移用）
+ */
+export function useCanvasSize(
+  designSize: { width: number; height: number },
+  options?: { presetCompensation?: number }
+) {
+  const { width: designW, height: designH } = designSize
+  const compensation = options?.presetCompensation ?? 1.0
+
+  const containerRef = useRef<HTMLDivElement | null>(null)
+  const [size, setSize] = useState({ width: designW, height: designH })
+
+  useEffect(() => {
+    const el = containerRef.current
+    if (!el) return
+
+    const observer = new ResizeObserver((entries) => {
+      for (const entry of entries) {
+        const { width, height } = entry.contentRect
+        setSize({ width: Math.round(width), height: Math.round(height) })
+      }
+    })
+
+    observer.observe(el)
+    return () => observer.disconnect()
+  }, [])
+
+  const scale = size.width > 0 ? (size.width / designW) * compensation : 1
+
+  const font = useCallback(
+    (base: number): number => {
+      const scaled = base * scale
+      return Math.max(FONT_MIN, Math.min(FONT_MAX, Math.round(scaled)))
+    },
+    [scale]
+  )
+
+  const px = useCallback(
+    (design: number): number => design * scale,
+    [scale]
+  )
+
+  const canvasSize: CanvasSize = { width: size.width, height: size.height, font, px, scale }
+
+  return [containerRef, canvasSize] as const
+}

