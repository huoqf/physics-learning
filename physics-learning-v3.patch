+/**
+ * src/data/quantities/mechanics/rotatingDisk.ts
+ * 圆盘与圆锥摆模型物理量构建器
+ *
+ * ════════════════════════════════════════════════════════════════════════════
+ * 设计规范：
+ * • 物理量与 UI 解耦（纯数据，无渲染）
+ * • 与知识树节点 mechanics-3-3 对应
+ * • 颜色 token 引用 @/theme/physics
+ * ════════════════════════════════════════════════════════════════════════════
+ */
+
+export interface PhysicsQuantity {
+  id: string
+  label: string
+  symbol: string
+  unit: string
+  value: number
+  colorToken: string
+  chartSeries?: string
+}
+
+/**
+ * 构建圆盘与圆锥摆的物理量展示数据
+ *
+ * @param state 当前物理状态
+ * @param params 当前参数
+ * @param model 模型类型
+ */
+export function buildRotatingDiskQuantities(
+  state: {
+    omega: number
+    centripetalForce: number
+    period: number
+    linearVelocity: number
+    thetaDeg: number
+    rotationRadius: number
+    tension: number
+    requiredFriction: number
+    maxFriction: number
+    safetyFactor: number
+    isCritical: boolean
+    omegaCrit: number
+  },
+  params: {
+    model: 'cone-pendulum' | 'rotating-disk'
+    L: number
+    m: number
+    g: number
+  },
+  formulas?: {
+    centripetalFormula: string
+    criticalFormula: string
+  }
+): PhysicsQuantity[] {
+  const { model } = params
+
+  const base: PhysicsQuantity[] = [
+    {
+      id: 'rotating-omega',
+      label: '角速度',
+      symbol: 'ω',
+      unit: 'rad/s',
+      value: state.omega,
+      colorToken: 'angularVelocity',
+      chartSeries: 'primary',
+    },
+    {
+      id: 'rotating-velocity',
+      label: '线速度',
+      symbol: 'v',
+      unit: 'm/s',
+      value: state.linearVelocity,
+      colorToken: 'velocity',
+      chartSeries: 'primary',
+    },
+    {
+      id: 'rotating-period',
+      label: '周期',
+      symbol: 'T',
+      unit: 's',
+      value: state.period,
+      colorToken: 'period',
+      chartSeries: 'secondary',
+    },
+    {
+      id: 'rotating-centripetal',
+      label: '向心力',
+      symbol: 'F_n',
+      unit: 'N',
+      value: state.centripetalForce,
+      colorToken: 'forceNet',
+      chartSeries: 'primary',
+    },
+  ]
+
+  if (model === 'cone-pendulum') {
+    return [
+      ...base,
+      {
+        id: 'rotating-theta',
+        label: '摆角',
+        symbol: 'θ',
+        unit: '°',
+        value: state.thetaDeg,
+        colorToken: 'forceNet',
+        chartSeries: 'primary',
+      },
+      {
+        id: 'rotating-radius',
+        label: '旋转半径',
+        symbol: 'r',
+        unit: 'm',
+        value: state.rotationRadius,
+        colorToken: 'displacement',
+        chartSeries: 'secondary',
+      },
+      {
+        id: 'rotating-tension',
+        label: '绳拉力',
+        symbol: 'T',
+        unit: 'N',
+        value: state.tension,
+        colorToken: 'forceNet',
+        chartSeries: 'primary',
+      },
+    ]
+  } else {
+    return [
+      ...base,
+      {
+        id: 'rotating-friction',
+        label: '静摩擦力',
+        symbol: 'f',
+        unit: 'N',
+        value: state.requiredFriction,
+        colorToken: 'appliedForce',
+        chartSeries: 'primary',
+      },
+      {
+        id: 'rotating-maxfriction',
+        label: '最大静摩擦',
+        symbol: 'f_max',
+        unit: 'N',
+        value: state.maxFriction,
+        colorToken: 'forceNet',
+        chartSeries: 'secondary',
+      },
+      {
+        id: 'rotating-safety',
+        label: '安全因子',
+        symbol: 'f/f_max',
+        unit: '',
+        value: state.safetyFactor,
+        colorToken: state.isCritical ? 'acceleration' : 'kineticEnergy',
+        chartSeries: 'tertiary',
+      },
+      {
+        id: 'rotating-omega-crit',
+        label: '临界角速度',
+        symbol: 'ω_crit',
+        unit: 'rad/s',
+        value: state.omegaCrit,
+        colorToken: 'forceNet',
+        chartSeries: 'tertiary',
+      },
+    ]
+  }
+}
+
+/**
+ * 圆盘与圆锥摆关键公式卡片数据
+ */
+export function getRotatingDiskFormulas(model: 'cone-pendulum' | 'rotating-disk') {
+  const base = [
+    {
+      id: 'centripetal-formula',
+      label: '向心力定义',
+      latex: 'F_n = m\\omega^2 r',
+      description: '水平方向的合外力提供向心力',
+    },
+  ]
+
+  if (model === 'cone-pendulum') {
+    return [
+      ...base,
+      {
+        id: 'cone-pendulum-tan',
+        label: '摆角关系',
+        latex: '\\tan\\theta = \\frac{\\omega^2 L\\sin\\theta}{g}',
+        description: '竖直方向力平衡 + 水平向心力',
+      },
+      {
+        id: 'cone-pendulum-cos',
+        label: '摆角余弦',
+        latex: '\\cos\\theta = \\frac{g}{\\omega^2 L}',
+        description: '推导：tanθ = ω²Lsinθ/g → cosθ = g/(ω²L)',
+      },
+      {
+        id: 'cone-pendulum-tension',
+        label: '绳拉力',
+        latex: 'T = \\frac{mg}{\\cos\\theta}',
+        description: '由竖直方向平衡 T·cosθ = mg 推导',
+      },
+    ]
+  } else {
+    return [
+      ...base,
+      {
+        id: 'friction-formula',
+        label: '静摩擦力提供向心力',
+        latex: 'f = m\\omega^2 r',
+        description: '物体在旋转圆盘上随盘转动，摩擦力提供向心力',
+      },
+      {
+        id: 'max-friction',
+        label: '最大静摩擦力',
+        latex: 'f_{\\max} = \\mu mg',
+        description: '最大静摩擦力由正压力与摩擦系数决定',
+      },
+      {
+        id: 'critical-omega',
+        label: '临界角速度',
+        latex: '\\omega_{\\текст{crit}} = \\sqrt{\\frac{\\mu g}{r}}',
+        description: '令 f = f_max，求得临界角速度公式',
+      },
+    ]
+  }
+}

