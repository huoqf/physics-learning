+/**
+ * src/utils/coordinate.ts
+ * 物理坐标系 ↔ Canvas 画布坐标转换工具
+ *
+ * 用途：将物理世界坐标（m/s）映射到 SVG 设计坐标（px）
+ */
+
+/**
+ * 计算画布比例尺
+ *
+ * @param sceneWidth  场景宽度 px
+ * @param sceneHeight 场景高度 px
+ * @param world       物理世界范围 { xMax, yMax }
+ * @param padding     内边距 px
+ */
+export function computeScale(
+  sceneWidth: number,
+  sceneHeight: number,
+  world: { xMax: number; yMax: number },
+  padding = 40
+) {
+  const scaleX = (sceneWidth - padding * 2) / world.xMax
+  const scaleY = (sceneHeight - padding * 2) / world.yMax
+  return Math.min(scaleX, scaleY)
+}
+
+/**
+ * 将物理坐标转换为 Canvas 坐标
+ *
+ * @param x 物理坐标 x (m)
+ * @param y 物理坐标 y (m)
+ * @param originX 画布原点 x px
+ * @param originY 画布原点 y px
+ * @param scale 比例尺 px/m
+ */
+export function physicsToCanvasWithOrigin(
+  x: number,
+  y: number,
+  originX: number,
+  originY: number,
+  scale: number
+) {
+  return {
+    x: originX + x * scale,
+    y: originY - y * scale,  // y 轴取反（物理 y 向上）
+  }
+}

