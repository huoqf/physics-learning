+++ b/tests/physics/rotatingDisk.test.ts
@@ -0,0 +1,174 @@
+/**
+ * tests/physics/rotatingDisk.test.ts
+ * 圆盘与圆锥摆物理层单元测试
+ *
+ * ════════════════════════════════════════════════════════════════════════════
+ * 测试覆盖：
+ * • 圆锥摆：tanθ = ω²·L·sinθ/g, cosθ = g/(ω²L)
+ * • 旋转圆盘：f = mω²r, ω_crit = √(μg/r)
+ * • 临界判定：摩擦力占比 >= 1 时 isCritical
+ * • 离心判定：ω > ω_crit 时 isFlyOff
+ * • 向心力 F_n = mω²r
+ * • 历史采样点生成
+ * ════════════════════════════════════════════════════════════════════════════
+ */
+import { describe, it, expect } from 'vitest'
+import {
+  computeRotatingDiskConstants,
+  computeRotatingDiskStateAtTime,
+  generateRotatingDiskHistory,
+} from '@/physics/circular'
+
+describe('圆盘与圆锥摆物理层', () => {
+  // ─── 基础参数 ─────────────────────────────────────────────────────
+  const CONE_PARAMS = {
+    model: 'cone-pendulum' as const,
+    omega: 3.0,
+    L: 0.8,
+    mu: 0.5,
+    g: 9.8,
+    m: 1.0,
+  }
+
+  const DISK_PARAMS = {
+    model: 'rotating-disk' as const,
+    omega: 3.0,
+    L: 0.5,  // 圆盘半径
+    mu: 0.5,
+    g: 9.8,
+    m: 1.0,
+  }
+
+  describe('computeRotatingDiskConstants', () => {
+    it('圆锥摆：理想模型无明确临界（ω_crit 较大）', () => {
+      const { omegaCrit } = computeRotatingDiskConstants(CONE_PARAMS)
+      expect(omegaCrit).toBeGreaterThan(0)
+      expect(Number.isFinite(omegaCrit)).toBe(true)
+    })
+
+    it('旋转圆盘：临界角速度 ω_crit = √(μg/r)', () => {
+      const { omegaCrit } = computeRotatingDiskConstants(DISK_PARAMS)
+      // ω_crit = √(μg/r) = √(0.5×9.8/0.5) = √9.8 ≈ 3.13 rad/s
+      expect(omegaCrit).toBeCloseTo(Math.sqrt((0.5 * 9.8) / 0.5), 1)
+    })
+
+    it('旋转圆盘：r=0 时 ω_crit = Infinity', () => {
+      const { omegaCrit } = computeRotatingDiskConstants({
+        ...DISK_PARAMS,
+        L: 0,
+      })
+      expect(Number.isFinite(omegaCrit)).toBe(false)
+    })
+  })
+
+  describe('computeRotatingDiskStateAtTime', () => {
+    describe('圆锥摆模式', () => {
+      it('ω=0 时，摆角 θ=0（静止）', () => {
+        const state = computeRotatingDiskStateAtTime(0, { ...CONE_PARAMS, omega: 0 })
+        expect(state.thetaDeg).toBeCloseTo(0, 1)
+        expect(state.centripetalForce).toBeCloseTo(0, 4)
+      })
+
+      it('ω 增大时，摆角 θ 增大', () => {
+        const stateSlow = computeRotatingDiskStateAtTime(0, { ...CONE_PARAMS, omega: 2 })
+        const stateFast = computeRotatingDiskStateAtTime(0, { ...CONE_PARAMS, omega: 5 })
+        expect(stateFast.thetaDeg).toBeGreaterThan(stateSlow.thetaDeg)
+      })
+
+      it('向心力 F_n = mω²L', () => {
+        const state = computeRotatingDiskStateAtTime(0, CONE_PARAMS)
+        const expectedForce = 1.0 * 3.0 * 3.0 * 0.8
+        expect(state.centripetalForce).toBeCloseTo(expectedForce, 4)
+      })
+
+      it('绳拉力 T = mg / cosθ', () => {
+        const state = computeRotatingDiskStateAtTime(0, CONE_PARAMS)
+        const cosTheta = Math.cos(state.theta)
+        const expectedT = (1.0 * 9.8) / cosTheta
+        expect(state.tension).toBeCloseTo(expectedT, 2)
+      })
+
+      it('旋转半径 r = L·sinθ', () => {
+        const state = computeRotatingDiskStateAtTime(0, CONE_PARAMS)
+        const expectedR = 0.8 * Math.sin(state.theta)
+        expect(state.rotationRadius).toBeCloseTo(expectedR, 4)
+      })
+    })
+
+    describe('旋转圆盘模式', () => {
+      it('向心力 F_n = mω²r', () => {
+        const state = computeRotatingDiskStateAtTime(0, DISK_PARAMS)
+        const expectedForce = 1.0 * 3.0 * 3.0 * 0.5
+        expect(state.centripetalForce).toBeCloseTo(expectedForce, 4)
+      })
+
+      it('所需摩擦力 f = mω²r', () => {
+        const state = computeRotatingDiskStateAtTime(0, DISK_PARAMS)
+        expect(state.requiredFriction).toBeCloseTo(state.centripetalForce, 4)
+      })
+
+      it('最大摩擦力 f_max = μmg', () => {
+        const state = computeRotatingDiskStateAtTime(0, DISK_PARAMS)
+        const expectedMax = 0.5 * 1.0 * 9.8
+        expect(state.maxFriction).toBeCloseTo(expectedMax, 4)
+      })
+
+      it('ω=3 rad/s 时，摩擦力占比 < 1（未达临界）', () => {
+        const state = computeRotatingDiskStateAtTime(0, DISK_PARAMS)
+        // f = mω²r = 1×9×0.5 = 4.5
+        // f_max = μmg = 0.5×1×9.8 = 4.9
+        // 比值 ≈ 0.918 < 1
+        expect(state.frictionRatio).toBeLessThan(1)
+        expect(state.isCritical).toBe(false)
+        expect(state.isFlyOff).toBe(false)
+      })
+
+      it('ω > ω_crit 时，isFlyOff = true', () => {
+        // ω = 5 > ω_crit ≈ 3.13
+        const state = computeRotatingDiskStateAtTime(0, { ...DISK_PARAMS, omega: 5 })
+        expect(state.isFlyOff).toBe(true)
+        expect(state.isCritical).toBe(true)
+      })
+    })
+  })
+
+  describe('generateRotatingDiskHistory', () => {
+    it('生成指定数量的采样点', () => {
+      const history = generateRotatingDiskHistory(6.0, CONE_PARAMS, 50)
+      expect(history.forcePoints).toHaveLength(51)
+      expect(history.anglePoints).toHaveLength(51)
+    })
+
+    it('向心力曲线单调递增（ω 增大 → F_n 增大）', () => {
+      const history = generateRotatingDiskHistory(6.0, CONE_PARAMS, 50)
+      for (let i = 1; i < history.forcePoints.length; i++) {
+        expect(history.forcePoints[i].force).toBeGreaterThanOrEqual(
+          history.forcePoints[i - 1].force
+        )
+      }
+    })
+
+    it('圆锥摆摆角随 ω 单调递增', () => {
+      const history = generateRotatingDiskHistory(6.0, CONE_PARAMS, 50)
+      for (let i = 1; i < history.anglePoints.length; i++) {
+        expect(history.anglePoints[i].angle).toBeGreaterThanOrEqual(
+          history.anglePoints[i - 1].angle
+        )
+      }
+    })
+
+    it('圆盘摩擦力曲线在临界点后无法继续增长（被 f_max 钳制）', () => {
+      const history = generateRotatingDiskHistory(6.0, DISK_PARAMS, 50)
+      const { omegaCrit } = computeRotatingDiskConstants(DISK_PARAMS)
+
+      // 在临界点之后，摩擦力应该被 f_max 钳制
+      const postCriticalPoints = history.frictionPoints.filter(
+        p => p.omega > omegaCrit
+      )
+      // f 应该趋近于 f_max（略有数值误差）
+      for (const pt of postCriticalPoints) {
+        expect(pt.friction).toBeLessThanOrEqual(pt.maxFriction * 1.01)
+      }
+    })
+  })
+})

