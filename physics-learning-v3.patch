--- /dev/null
+++ b/src/features/mechanics/circular/rotating-disk/components/RotatingDiskCharts.tsx
@@ -0,0 +1,380 @@
+/**
+ * src/features/mechanics/circular/rotating-disk/components/RotatingDiskCharts.tsx
+ * 圆盘与圆锥摆图表面板（splitH 右侧）
+ *
+ * ════════════════════════════════════════════════════════════════════════════
+ * 合规要点：
+ * • 三图表垂直堆叠（HTML flex 纵向）
+ * • 图表配色引用 VT_CHART_COLORS / CHART_COLORS / DYNAMICS_COLORS / CANVAS_COLORS
+ * • 时间同步虚线（当前 ω 垂直扫描线）→ CHART_COLORS.asymptote
+ * • 临界点标记 → KINEMATICS_COLORS.acceleration
+ * ════════════════════════════════════════════════════════════════════════════
+ */
+import React from 'react'
+import {
+  VT_CHART_COLORS,
+  CHART_COLORS,
+  DYNAMICS_COLORS,
+  KINEMATICS_COLORS,
+  CANVAS_COLORS,
+} from '@/theme/physics'
+import type { RotatingDiskPhysicsResult } from '../hooks/useRotatingDiskPhysics'
+
+// ─── 图表尺寸常量 ────────────────────────────────────────────────────
+const CHART_PADDING_X = 40
+const CHART_PADDING_Y = 28
+const LABEL_HEIGHT = 20
+
+interface RotatingDiskChartsProps {
+  physics: RotatingDiskPhysicsResult
+  model: 'cone-pendulum' | 'rotating-disk'
+  currentOmega: number
+}
+
+/**
+ * 图表面板（splitH 右侧）
+ *
+ * 布局：三图垂直堆叠
+ * • 圆锥摆：F_n-ω 图 + θ-ω 图
+ * • 圆盘：F_n-ω 图 + 摩擦力-ω 图
+ */
+export function RotatingDiskCharts({ physics, model, currentOmega }: RotatingDiskChartsProps) {
+  const { forcePoints, anglePoints, frictionPoints, omegaMax, omegaCrit } = physics
+
+  // 当前 ω 在图上的归一化位置（用于同步扫描线）
+  const syncRatio = omegaMax > 0 ? currentOmega / omegaMax : 0
+
+  return (
+    <div className="flex flex-col w-full h-full gap-1 min-h-0">
+      {/* ─── 上图：向心力-角速度曲线 ──────────────────── */}
+      <div className="flex-1 min-h-0 flex flex-col">
+        <div className="text-xs font-medium text-neutral-600 px-1 mb-0.5">
+          向心力 F_n - ω
+        </div>
+        <div className="flex-1 bg-white rounded-lg border border-neutral-200 p-1 shadow-sm min-h-0">
+          <ForceOmegaChart
+            points={forcePoints}
+            currentOmega={currentOmega}
+            omegaMax={omegaMax}
+            syncRatio={syncRatio}
+          />
+        </div>
+      </div>
+
+      {/* ─── 下图：摆角 / 摩擦力 ──────────────────────── */}
+      <div className="flex-1 min-h-0 flex flex-col">
+        <div className="text-xs font-medium text-neutral-600 px-1 mb-0.5">
+          {model === 'cone-pendulum' ? '摆角 θ - ω' : '摩擦力 f - ω'}
+        </div>
+        <div className="flex-1 bg-white rounded-lg border border-neutral-200 p-1 shadow-sm min-h-0">
+          {model === 'cone-pendulum' ? (
+            <AngleOmegaChart points={anglePoints} currentOmega={currentOmega} omegaMax={omegaMax} syncRatio={syncRatio} />
+          ) : (
+            <FrictionOmegaChart
+              points={frictionPoints}
+              currentOmega={currentOmega}
+              omegaMax={omegaMax}
+              omegaCrit={omegaCrit}
+              syncRatio={syncRatio}
+            />
+          )}
+        </div>
+      </div>
+    </div>
+  )
+}
+
+// ─── 网格辅助函数（避免重复）────────────────────────────────────────
+function gridLines(toX: (omega: number) => number, omegaMax: number, chartH: number) {
+  return [0.25, 0.5, 0.75].map(r => (
+    <line
+      key={r}
+      x1={toX(r * omegaMax)} y1={CHART_PADDING_Y}
+      x2={toX(r * omegaMax)} y2={chartH - CHART_PADDING_Y}
+      stroke={CANVAS_COLORS.grid} strokeWidth={0.5} strokeDasharray="2,2"
+    />
+  ))
+}
+
+function xAxis(chartW: number, chartH: number) {
+  return (
+    <line
+      x1={CHART_PADDING_X} y1={chartH - CHART_PADDING_Y}
+      x2={chartW - CHART_PADDING_X} y2={chartH - CHART_PADDING_Y}
+      stroke={CHART_COLORS.tickMark} strokeWidth={0.8}
+    />
+  )
+}
+
+// ─── 向心力-角速度图表 ──────────────────────────────────────────────
+
+function ForceOmegaChart({
+  points,
+  currentOmega,
+  omegaMax,
+  syncRatio,
+}: {
+  points: Array<{ omega: number; force: number }>
+  currentOmega: number
+  omegaMax: number
+  syncRatio: number
+}) {
+  const chartW = 260
+  const chartH = 120
+
+  const toX = (omega: number) => CHART_PADDING_X + (omega / omegaMax) * (chartW - CHART_PADDING_X * 2)
+  const toY = (force: number, maxForce: number) =>
+    CHART_PADDING_Y + (1 - force / maxForce) * (chartH - CHART_PADDING_Y * 2)
+
+  const activePoints = points.filter(p => p.omega <= currentOmega)
+  const maxForce = Math.max(...points.map(p => p.force), 1)
+
+  return (
+    <svg width="100%" height="100%" viewBox={`0 0 ${chartW} ${chartH + LABEL_HEIGHT}`} preserveAspectRatio="xMidYMid meet">
+      {gridLines(toX, omegaMax, chartH)}
+      {xAxis(chartW, chartH)}
+
+      {/* 曲线（预告 + 已到达） */}
+      {points.length > 1 && (
+        <>
+          <path
+            d={`M ${points.map(p => `${toX(p.omega).toFixed(1)},${toY(p.force, maxForce).toFixed(1)}`).join(' L ')}`}
+            fill="none"
+            stroke={VT_CHART_COLORS.primary}
+            strokeWidth={1.5}
+            strokeDasharray="4,3"
+            opacity={0.35}
+          />
+          {activePoints.length > 1 && (
+            <path
+              d={`M ${activePoints.map(p => `${toX(p.omega).toFixed(1)},${toY(p.force, maxForce).toFixed(1)}`).join(' L ')}`}
+              fill="none"
+              stroke={VT_CHART_COLORS.primary}
+              strokeWidth={2}
+            />
+          )}
+        </>
+      )}
+
+      {/* 同步扫描线 — asymptote */}
+      {syncRatio > 0 && syncRatio < 1 && (
+        <line
+          x1={toX(currentOmega)} y1={CHART_PADDING_Y}
+          x2={toX(currentOmega)} y2={chartH - CHART_PADDING_Y}
+          stroke={CHART_COLORS.asymptote} strokeWidth={1.5} strokeDasharray="3,3" opacity={0.7}
+        />
+      )}
+
+      {/* 当前点 */}
+      {currentOmega > 0 && currentOmega <= omegaMax && (
+        <circle
+          cx={toX(currentOmega)}
+          cy={toY(activePoints[activePoints.length - 1]?.force ?? 0, maxForce)}
+          r={4}
+          fill={VT_CHART_COLORS.primary}
+        />
+      )}
+
+      {/* 轴标签 */}
+      <text x={chartW / 2} y={chartH + LABEL_HEIGHT - 4} fontSize={8} fill={CHART_COLORS.tickLabel} textAnchor="middle">
+        ω / rad·s⁻¹
+      </text>
+      <text x={10} y={chartH / 2} fontSize={8} fill={CHART_COLORS.tickLabel} textAnchor="middle" transform={`rotate(-90, 10, ${chartH / 2})`}>
+        F_n / N
+      </text>
+    </svg>
+  )
+}
+
+// ─── 摆角-角速度图表 ────────────────────────────────────────────────
+
+function AngleOmegaChart({
+  points,
+  currentOmega,
+  omegaMax,
+  syncRatio,
+}: {
+  points: Array<{ omega: number; angle: number }>
+  currentOmega: number
+  omegaMax: number
+  syncRatio: number
+}) {
+  const chartW = 260
+  const chartH = 120
+
+  const toX = (omega: number) => CHART_PADDING_X + (omega / omegaMax) * (chartW - CHART_PADDING_X * 2)
+  const toY = (angle: number) =>
+    CHART_PADDING_Y + (1 - angle / 90) * (chartH - CHART_PADDING_Y * 2)
+
+  const activePoints = points.filter(p => p.omega <= currentOmega)
+
+  return (
+    <svg width="100%" height="100%" viewBox={`0 0 ${chartW} ${chartH + LABEL_HEIGHT}`} preserveAspectRatio="xMidYMid meet">
+      {gridLines(toX, omegaMax, chartH)}
+      {xAxis(chartW, chartH)}
+
+      {/* 曲线 */}
+      {points.length > 1 && (
+        <>
+          <path
+            d={`M ${points.map(p => `${toX(p.omega).toFixed(1)},${toY(p.angle).toFixed(1)}`).join(' L ')}`}
+            fill="none"
+            stroke={DYNAMICS_COLORS.forceNet}
+            strokeWidth={1.5}
+            strokeDasharray="4,3"
+            opacity={0.35}
+          />
+          {activePoints.length > 1 && (
+            <path
+              d={`M ${activePoints.map(p => `${toX(p.omega).toFixed(1)},${toY(p.angle).toFixed(1)}`).join(' L ')}`}
+              fill="none"
+              stroke={DYNAMICS_COLORS.forceNet}
+              strokeWidth={2}
+            />
+          )}
+        </>
+      )}
+
+      {/* 同步扫描线 — asymptote */}
+      {syncRatio > 0 && syncRatio < 1 && (
+        <line
+          x1={toX(currentOmega)} y1={CHART_PADDING_Y}
+          x2={toX(currentOmega)} y2={chartH - CHART_PADDING_Y}
+          stroke={CHART_COLORS.asymptote} strokeWidth={1.5} strokeDasharray="3,3" opacity={0.7}
+        />
+      )}
+
+      {/* 当前点 */}
+      {currentOmega > 0 && currentOmega <= omegaMax && (
+        <circle
+          cx={toX(currentOmega)}
+          cy={toY(activePoints[activePoints.length - 1]?.angle ?? 0)}
+          r={4}
+          fill={DYNAMICS_COLORS.forceNet}
+        />
+      )}
+
+      {/* 轴标签 */}
+      <text x={chartW / 2} y={chartH + LABEL_HEIGHT - 4} fontSize={8} fill={CHART_COLORS.tickLabel} textAnchor="middle">
+        ω / rad·s⁻¹
+      </text>
+      <text x={10} y={chartH / 2} fontSize={8} fill={CHART_COLORS.tickLabel} textAnchor="middle" transform={`rotate(-90, 10, ${chartH / 2})`}>
+        θ / °
+      </text>
+    </svg>
+  )
+}
+
+// ─── 摩擦力-角速度图表 ──────────────────────────────────────────────
+
+function FrictionOmegaChart({
+  points,
+  currentOmega,
+  omegaMax,
+  omegaCrit,
+  syncRatio,
+}: {
+  points: Array<{ omega: number; friction: number; maxFriction: number }>
+  currentOmega: number
+  omegaMax: number
+  omegaCrit: number
+  syncRatio: number
+}) {
+  const chartW = 260
+  const chartH = 120
+
+  const toX = (omega: number) => CHART_PADDING_X + (omega / omegaMax) * (chartW - CHART_PADDING_X * 2)
+  const toY = (friction: number, maxF: number) =>
+    CHART_PADDING_Y + (1 - friction / maxF) * (chartH - CHART_PADDING_Y * 2)
+
+  const activePoints = points.filter(p => p.omega <= currentOmega)
+  const maxF = Math.max(...points.map(p => p.maxFriction), 1)
+
+  return (
+    <svg width="100%" height="100%" viewBox={`0 0 ${chartW} ${chartH + LABEL_HEIGHT}`} preserveAspectRatio="xMidYMid meet">
+      {gridLines(toX, omegaMax, chartH)}
+      {xAxis(chartW, chartH)}
+
+      {/* 最大摩擦力水平线（临界线）— acceleration 红 */}
+      {points.length > 0 && (
+        <line
+          x1={CHART_PADDING_X} y1={toY(maxF, maxF)}
+          x2={chartW - CHART_PADDING_X} y2={toY(maxF, maxF)}
+          stroke={KINEMATICS_COLORS.acceleration}
+          strokeWidth={1}
+          strokeDasharray="4,4"
+          opacity={0.6}
+        />
+      )}
+
+      {/* 临界角速度垂直线 — acceleration 红 */}
+      {omegaCrit < omegaMax && (
+        <line
+          x1={toX(omegaCrit)} y1={CHART_PADDING_Y}
+          x2={toX(omegaCrit)} y2={chartH - CHART_PADDING_Y}
+          stroke={KINEMATICS_COLORS.acceleration}
+          strokeWidth={1}
+          strokeDasharray="4,4"
+          opacity={0.6}
+        />
+      )}
+
+      {/* 摩擦力曲线 */}
+      {points.length > 1 && (
+        <>
+          <path
+            d={`M ${points.map(p => `${toX(p.omega).toFixed(1)},${toY(p.friction, maxF).toFixed(1)}`).join(' L ')}`}
+            fill="none"
+            stroke={DYNAMICS_COLORS.forceNet}
+            strokeWidth={1.5}
+            strokeDasharray="4,3"
+            opacity={0.35}
+          />
+          {activePoints.length > 1 && (
+            <path
+              d={`M ${activePoints.map(p => `${toX(p.omega).toFixed(1)},${toY(p.friction, maxF).toFixed(1)}`).join(' L ')}`}
+              fill="none"
+              stroke={DYNAMICS_COLORS.forceNet}
+              strokeWidth={2}
+            />
+          )}
+        </>
+      )}
+
+      {/* 同步扫描线 — asymptote */}
+      {syncRatio > 0 && syncRatio < 1 && (
+        <line
+          x1={toX(currentOmega)} y1={CHART_PADDING_Y}
+          x2={toX(currentOmega)} y2={chartH - CHART_PADDING_Y}
+          stroke={CHART_COLORS.asymptote} strokeWidth={1.5} strokeDasharray="3,3" opacity={0.7}
+        />
+      )}
+
+      {/* 当前点 */}
+      {currentOmega > 0 && currentOmega <= omegaMax && (
+        <circle
+          cx={toX(currentOmega)}
+          cy={toY(activePoints[activePoints.length - 1]?.friction ?? 0, maxF)}
+          r={4}
+          fill={DYNAMICS_COLORS.forceNet}
+        />
+      )}
+
+      {/* 图例 */}
+      <g transform={`translate(${CHART_PADDING_X + 5}, ${CHART_PADDING_Y + 5})`}>
+        <line x1={0} y1={0} x2={12} y2={0} stroke={DYNAMICS_COLORS.forceNet} strokeWidth={2} />
+        <text x={16} y={3} fontSize={7} fill={CANVAS_COLORS.annotation}>f(ω)</text>
+        <line x1={35} y1={0} x2={47} y2={0} stroke={KINEMATICS_COLORS.acceleration} strokeWidth={1} strokeDasharray="4,4" />
+        <text x={51} y={3} fontSize={7} fill={CANVAS_COLORS.annotation}>f_max</text>
+      </g>
+
+      {/* 轴标签 */}
+      <text x={chartW / 2} y={chartH + LABEL_HEIGHT - 4} fontSize={8} fill={CHART_COLORS.tickLabel} textAnchor="middle">
+        ω / rad·s⁻¹
+      </text>
+      <text x={10} y={chartH / 2} fontSize={8} fill={CHART_COLORS.tickLabel} textAnchor="middle" transform={`rotate(-90, 10, ${chartH / 2})`}>
+        f / N
+      </text>
+    </svg>
+  )
+}

