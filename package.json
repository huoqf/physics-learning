{
  "name": "physics-learning",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "audit:deps": "npm audit --audit-level=moderate",
    "check:font-size": "node scripts/check-font-size.mjs",
    "check:large-files": "node scripts/check-large-files.mjs",
    "check:no-raf": "node scripts/check-no-raf.mjs",
    "check:no-marker": "node scripts/check-no-marker.mjs",
    "check:architecture": "npm run check:font-size && npm run check:viewport-legacy && npm run check:large-files && npm run check:no-raf && npm run check:no-marker",
    "check": "npm run build && npm test -- --run && npm run audit:deps && npm run check:architecture",
    "prepare": "lefthook install",
    "check:viewport-legacy": "node scripts/check-viewport-legacy.mjs"
  },
  "dependencies": {
    "idb": "^8.0.2",
    "katex": "^0.16.11",
    "lucide-react": "^0.460.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-router-dom": "^7.1.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/katex": "^0.16.7",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@typescript-eslint/eslint-plugin": "^8.23.0",
    "@typescript-eslint/parser": "^8.23.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.6",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.20.1",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.15.0",
    "jsdom": "^26.0.0",
    "lefthook": "^2.1.9",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.2",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  }
}
